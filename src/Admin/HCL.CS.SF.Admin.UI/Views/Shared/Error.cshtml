@model Microsoft.AspNetCore.Mvc.RazorPages.PageModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="hcl-page-header">
    <h1 class="hcl-page-title">Something went wrong</h1>
    <p class="hcl-page-subtitle">An unexpected error occurred while processing your request.</p>
</div>

<div class="hcl-card">
    <div class="hcl-card-body" style="text-align: center; padding: 3rem;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="64" height="64" style="margin: 0 auto 1.5rem; opacity: 0.5; color: var(--hcl-danger);">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>

        <h2 style="color: var(--hcl-text-primary); margin-bottom: 0.5rem;">Error</h2>
        <p style="color: var(--hcl-text-secondary); margin-bottom: 2rem;">
            The server encountered an internal error and was unable to complete your request.
            Please try again later or contact your administrator.
        </p>

        @if (ViewData["RequestId"] != null)
        {
            <p style="color: var(--hcl-text-muted); font-size: 0.8125rem; margin-bottom: 1.5rem;">
                Request ID: <code style="color: var(--hcl-accent-cyan);">@ViewData["RequestId"]</code>
            </p>
        }

        <a href="/Admin/Dashboard" class="hcl-btn hcl-btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Back to Dashboard</span>
        </a>
    </div>
</div>
