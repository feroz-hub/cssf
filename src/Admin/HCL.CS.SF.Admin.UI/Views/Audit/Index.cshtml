@{
    /* Audit Trail - AJAX-driven search with pagination */
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">Audit Trail</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            Search and review all system audit events
        </p>
    </div>
</div>

<!-- Filter Bar -->
<div class="hcl-card hcl-glass" style="padding: 1.25rem; margin-bottom: 1.5rem;">
    <div class="hcl-filter-bar" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 160px;">
            <label class="hcl-label">Action Type</label>
            <select class="hcl-select" id="filterActionType">
                <option value="">All</option>
                <option value="0">Create</option>
                <option value="1">Update</option>
                <option value="2">Delete</option>
                <option value="3">Read</option>
            </select>
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 160px;">
            <label class="hcl-label">Created By</label>
            <input type="text" class="hcl-input" id="filterCreatedBy" placeholder="Username..." />
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 160px;">
            <label class="hcl-label">From Date</label>
            <input type="date" class="hcl-input" id="filterFromDate" />
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 160px;">
            <label class="hcl-label">To Date</label>
            <input type="date" class="hcl-input" id="filterToDate" />
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 160px;">
            <label class="hcl-label">Search Value</label>
            <input type="text" class="hcl-input" id="filterSearchValue" placeholder="Table, column..." />
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0;">
            <button class="hcl-btn hcl-btn-primary" onclick="searchAudit(1)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Search
            </button>
        </div>
    </div>
</div>

<!-- Loading State -->
<div id="loadingState" style="display: none;">
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <div class="hcl-spinner" style="width: 40px; height: 40px; border: 3px solid var(--hcl-border); border-top-color: var(--hcl-accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem;"></div>
            <p style="color: var(--hcl-text-tertiary);">Searching audit records...</p>
        </div>
    </div>
</div>

<!-- Empty State -->
<div id="emptyState" style="display: none;">
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            <p style="color: var(--hcl-text-tertiary);">No audit records found. Adjust your filters and try again.</p>
        </div>
    </div>
</div>

<!-- Initial State -->
<div id="initialState">
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <p style="color: var(--hcl-text-tertiary);">Use the filters above and click Search to load audit records.</p>
        </div>
    </div>
</div>

<!-- Results Table -->
<div id="resultsContainer" style="display: none;">
    <div class="hcl-card hcl-glass">
        <div class="hcl-table-wrapper">
            <table class="hcl-table">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>Table Name</th>
                        <th>Created By</th>
                        <th>Date</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="auditTableBody">
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <div class="hcl-pagination" id="paginationContainer" style="margin-top: 1rem;">
    </div>
</div>

<!-- View Details Modal -->
<div class="hcl-modal-backdrop" id="auditDetailModal">
    <div class="hcl-modal" style="max-width: 800px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Audit Detail
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('auditDetailModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <div class="hcl-grid hcl-grid-2" style="gap: 1rem;">
                <div>
                    <label class="hcl-label" style="margin-bottom: 0.5rem;">Old Value</label>
                    <pre id="detailOldValue" style="background: var(--hcl-bg-tertiary); border: 1px solid var(--hcl-border); border-radius: 0.5rem; padding: 1rem; font-size: 0.8rem; overflow: auto; max-height: 400px; color: var(--hcl-text-secondary); white-space: pre-wrap; word-break: break-word;"></pre>
                </div>
                <div>
                    <label class="hcl-label" style="margin-bottom: 0.5rem;">New Value</label>
                    <pre id="detailNewValue" style="background: var(--hcl-bg-tertiary); border: 1px solid var(--hcl-border); border-radius: 0.5rem; padding: 1rem; font-size: 0.8rem; overflow: auto; max-height: 400px; color: var(--hcl-text-secondary); white-space: pre-wrap; word-break: break-word;"></pre>
                </div>
            </div>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('auditDetailModal')">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@media (max-width: 768px) {
        .hcl-filter-bar { flex-direction: column; }
        .hcl-filter-bar .hcl-form-group { min-width: 100% !important; }
        .hcl-grid-2 { grid-template-columns: 1fr !important; }
    }
</style>
<script>
    var currentPage = 1;
    var auditData = [];

    function getActionBadge(actionType) {
        var map = {
            '0': { label: 'Create', cls: 'hcl-badge-success' },
            '1': { label: 'Update', cls: 'hcl-badge-primary' },
            '2': { label: 'Delete', cls: 'hcl-badge-danger' },
            '3': { label: 'Read',   cls: 'hcl-badge-warning' },
            'Create': { label: 'Create', cls: 'hcl-badge-success' },
            'Update': { label: 'Update', cls: 'hcl-badge-primary' },
            'Delete': { label: 'Delete', cls: 'hcl-badge-danger' },
            'Read':   { label: 'Read',   cls: 'hcl-badge-warning' }
        };
        var info = map[actionType] || { label: actionType || 'Unknown', cls: 'hcl-badge-primary' };
        return '<span class="hcl-badge ' + info.cls + '">' + info.label + '</span>';
    }

    function formatJson(str) {
        if (!str) return '(empty)';
        try {
            return JSON.stringify(JSON.parse(str), null, 2);
        } catch (e) {
            return str;
        }
    }

    async function searchAudit(page) {
        currentPage = page || 1;

        document.getElementById('initialState').style.display = 'none';
        document.getElementById('emptyState').style.display = 'none';
        document.getElementById('resultsContainer').style.display = 'none';
        document.getElementById('loadingState').style.display = '';

        var payload = {
            actionType: document.getElementById('filterActionType').value || null,
            createdBy: document.getElementById('filterCreatedBy').value.trim() || null,
            fromDate: document.getElementById('filterFromDate').value || null,
            toDate: document.getElementById('filterToDate').value || null,
            searchValue: document.getElementById('filterSearchValue').value.trim() || null,
            page: {
                currentPage: currentPage,
                itemsPerPage: 10
            }
        };

        try {
            var result = await HCL.apiRequest('/Admin/Audit/Search', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            document.getElementById('loadingState').style.display = 'none';

            auditData = result.auditList || [];

            if (auditData.length === 0) {
                document.getElementById('emptyState').style.display = '';
                return;
            }

            renderTable(auditData);
            renderPagination(result.pageInfo || {});
            document.getElementById('resultsContainer').style.display = '';
        } catch (err) {
            document.getElementById('loadingState').style.display = 'none';
            document.getElementById('emptyState').style.display = '';
            HCL.toastError('Failed to search audit records.');
        }
    }

    function renderTable(items) {
        var tbody = document.getElementById('auditTableBody');
        var html = '';
        items.forEach(function(item, idx) {
            html += '<tr>' +
                '<td data-label="Action">' + getActionBadge(item.actionType) + '</td>' +
                '<td data-label="Table Name" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (item.tableName || 'N/A') + '</td>' +
                '<td data-label="Created By" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (item.createdBy || 'N/A') + '</td>' +
                '<td data-label="Date" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (item.createdOn ? HCL.formatDateTime(item.createdOn) : 'N/A') + '</td>' +
                '<td data-label="Actions" style="text-align: right;">' +
                    '<button class="hcl-btn hcl-btn-sm hcl-btn-ghost" onclick="viewAuditDetail(' + idx + ')">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
                        ' View Details' +
                    '</button>' +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    function renderPagination(pageInfo) {
        var container = document.getElementById('paginationContainer');
        var totalPages = pageInfo.totalPages || 1;
        var current = pageInfo.currentPage || 1;

        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        var html = '';
        html += '<button class="hcl-page-btn" onclick="searchAudit(' + (current - 1) + ')" ' + (current <= 1 ? 'disabled' : '') + '>&laquo; Prev</button>';

        var start = Math.max(1, current - 4);
        var end = Math.min(totalPages, start + 9);
        if (end - start < 9) start = Math.max(1, end - 9);

        for (var i = start; i <= end; i++) {
            html += '<button class="hcl-page-btn' + (i === current ? ' active' : '') + '" onclick="searchAudit(' + i + ')">' + i + '</button>';
        }

        html += '<button class="hcl-page-btn" onclick="searchAudit(' + (current + 1) + ')" ' + (current >= totalPages ? 'disabled' : '') + '>Next &raquo;</button>';
        container.innerHTML = html;
    }

    function viewAuditDetail(idx) {
        var item = auditData[idx];
        if (!item) return;
        document.getElementById('detailOldValue').textContent = formatJson(item.oldValue);
        document.getElementById('detailNewValue').textContent = formatJson(item.newValue);
        HCL.openModal('auditDetailModal');
    }
</script>
}
