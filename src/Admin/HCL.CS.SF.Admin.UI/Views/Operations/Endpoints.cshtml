<!-- Test Response Modal -->
<div class="hcl-modal" id="testResponseModal">
    <div style="background: var(--hcl-bg-secondary); border: 1px solid var(--hcl-border); border-radius: 12px; max-width: 700px; width: 100%; max-height: 80vh; display: flex; flex-direction: column;">
        <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--hcl-border); display: flex; justify-content: space-between; align-items: center;">
            <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);" id="testModalTitle">Endpoint Response</h3>
            <button class="hcl-btn hcl-btn-ghost hcl-btn-sm" onclick="HCL.closeModal('testResponseModal')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div style="padding: 1.5rem; overflow-y: auto; flex: 1;">
            <div id="testResponseStatus" style="margin-bottom: 1rem;"></div>
            <pre class="hcl-pre" style="max-height: 50vh; overflow: auto;"><code id="testResponseBody" class="hcl-code" style="white-space: pre-wrap; word-break: break-all;"></code></pre>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function copyEndpoint(id) {
        var el = document.getElementById(id);
        if (el) {
            HCL.copyToClipboard(el.textContent.trim());
            HCL.toastSuccess('URL copied to clipboard.');
        }
    }

    async function testEndpoint(id, method) {
        var el = document.getElementById(id);
        if (!el) return;
        var url = el.textContent.trim();

        document.getElementById('testModalTitle').textContent = method + ' ' + url.replace('@Html.Raw(authority)', '');
        document.getElementById('testResponseStatus').innerHTML = '<span class="hcl-badge">Loading...</span>';
        document.getElementById('testResponseBody').textContent = '';
        HCL.openModal('testResponseModal');

        try {
            var result = await HCL.apiRequest('/Admin/AuthTools/TestEndpoint', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: url, method: method })
            });

            var statusColor = result.statusCode >= 200 && result.statusCode < 300 ? '#22c55e' :
                              result.statusCode >= 400 ? '#ef4444' : '#f59e0b';
            document.getElementById('testResponseStatus').innerHTML =
                '<span class="hcl-badge" style="background: ' + statusColor + '22; color: ' + statusColor + '; font-size: 0.85rem;">' +
                result.statusCode + ' ' + (result.statusText || '') + '</span>';

            var body = result.body || '';
            try { body = JSON.stringify(JSON.parse(body), null, 2); } catch(e) {}
            document.getElementById('testResponseBody').textContent = body;
        } catch (err) {
            document.getElementById('testResponseStatus').innerHTML = '<span class="hcl-badge hcl-badge-danger">Error</span>';
            document.getElementById('testResponseBody').textContent = err.message || 'Request failed.';
        }
    }
</script>
}
