@{
    var authority = ViewBag.Authority as string ?? "https://localhost:5001";
}

<!-- Page Header -->
<div class="hcl-page-header" style="margin-bottom: 2rem;">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text" style="font-size: 2rem; font-weight: 700;">OIDC Protocol Endpoints</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            Standard OpenID Connect and OAuth 2.0 endpoint reference for <span class="hcl-code" style="font-size: 0.8rem;">@authority</span>
        </p>
    </div>
    <div class="hcl-page-actions">
        <a href="/Admin/Operations" class="hcl-btn hcl-btn-sm" style="background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Operations
        </a>
    </div>
</div>

<!-- Endpoints Card -->
<div class="hcl-card hcl-glass" style="margin-bottom: 2rem;">
    <div style="padding: 1.5rem;">
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem; color: #06b6d4;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            Discovery &amp; Metadata
        </h3>
        <div class="hcl-table-wrapper">
            <table class="hcl-table" id="endpointsTable">
                <thead>
                    <tr>
                        <th style="width: 70px;">Method</th>
                        <th>Endpoint</th>
                        <th style="width: 200px; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="hcl-badge hcl-badge-success">GET</span></td>
                        <td>
                            <div style="font-weight: 500; color: var(--hcl-text-primary); font-size: 0.875rem;">Discovery</div>
                            <code class="hcl-code" style="font-size: 0.8rem;" id="ep-discovery">@(authority)/.well-known/openid-configuration</code>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <button class="hcl-btn hcl-btn-ghost hcl-btn-sm" onclick="copyEndpoint('ep-discovery')" title="Copy URL">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                    Copy
                                </button>
                                <button class="hcl-btn hcl-btn-sm hcl-btn-secondary" onclick="testEndpoint('ep-discovery', 'GET')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                    Test
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="hcl-badge hcl-badge-success">GET</span></td>
                        <td>
                            <div style="font-weight: 500; color: var(--hcl-text-primary); font-size: 0.875rem;">JWKS</div>
                            <code class="hcl-code" style="font-size: 0.8rem;" id="ep-jwks">@(authority)/.well-known/openid-configuration/jwks</code>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <button class="hcl-btn hcl-btn-ghost hcl-btn-sm" onclick="copyEndpoint('ep-jwks')" title="Copy URL">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                    Copy
                                </button>
                                <button class="hcl-btn hcl-btn-sm hcl-btn-secondary" onclick="testEndpoint('ep-jwks', 'GET')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                    Test
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

