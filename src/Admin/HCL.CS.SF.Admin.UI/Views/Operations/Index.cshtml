@{
    var authority = ViewBag.Authority as string ?? "https://localhost:5001";
}

<!-- Page Header -->
<div class="hcl-page-header" style="margin-bottom: 2rem;">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text" style="font-size: 2rem; font-weight: 700;">Operations Center</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            System tools, diagnostics and protocol management
        </p>
    </div>
</div>

<!-- Operations Grid -->
<div class="hcl-grid hcl-grid-3" style="margin-bottom: 2rem;">

    <!-- API Explorer -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(59,130,246,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" width="22" height="22"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">API Explorer</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Test OIDC endpoints, inspect tokens, and debug authentication flows with the built-in API client.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/AuthTools" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- Token Revocation -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(239,68,68,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" width="22" height="22"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Token Revocation</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Search and revoke active access and refresh tokens by client or user.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/Revocation" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- Audit Trail -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(168,85,247,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" width="22" height="22"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Audit Trail</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                View detailed audit logs of all administrative actions and security events.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/Audit" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- Protocol Endpoints -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(6,182,212,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Protocol Endpoints</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Quick reference for all OIDC protocol endpoints with copy and test capabilities.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/Operations/Endpoints" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- Notifications -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(245,158,11,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" width="22" height="22"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Notifications</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Manage system notifications, email templates and delivery channels.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/Notifications" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- External Auth -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(16,185,129,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" width="22" height="22"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">External Auth</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Configure external identity providers such as Google, Azure AD, SAML and LDAP.
            </p>
            <div style="margin-top: 1rem;">
                <a href="/Admin/ExternalAuth" class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                    Go
                </a>
            </div>
        </div>
    </div>

    <!-- Health Check -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(34,197,94,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" width="22" height="22"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Health Check</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                Real-time health status of the identity server and dependent services.
            </p>
            <div style="margin-top: 1rem;" id="healthStatusContainer">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <div id="healthDot" style="width: 10px; height: 10px; border-radius: 50%; background: var(--hcl-text-tertiary);"></div>
                    <span id="healthLabel" style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Checking...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Discovery Document -->
    <div class="hcl-card hcl-glass hcl-hover-lift">
        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(99,102,241,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" width="22" height="22"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </div>
                <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">Discovery Document</h3>
            </div>
            <p style="color: var(--hcl-text-secondary); font-size: 0.85rem; flex: 1;">
                View the OpenID Connect discovery document with all server metadata.
            </p>
            <div style="margin-top: 1rem;">
                <a href="@(authority)/.well-known/openid-configuration" target="_blank" rel="noopener"
                   class="hcl-btn hcl-btn-primary hcl-btn-sm" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Open
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    (function() {
        var authority = '@Html.Raw(authority)';

        // Check health on load
        checkHealth();

        async function checkHealth() {
            var dot = document.getElementById('healthDot');
            var label = document.getElementById('healthLabel');
            try {
                var res = await fetch(authority + '/health', { method: 'GET', mode: 'cors' });
                if (res.ok) {
                    dot.style.background = '#22c55e';
                    dot.style.boxShadow = '0 0 6px rgba(34,197,94,0.5)';
                    label.textContent = 'Healthy';
                    label.style.color = '#22c55e';
                } else {
                    dot.style.background = '#f59e0b';
                    dot.style.boxShadow = '0 0 6px rgba(245,158,11,0.5)';
                    label.textContent = 'Degraded (' + res.status + ')';
                    label.style.color = '#f59e0b';
                }
            } catch (e) {
                dot.style.background = '#ef4444';
                dot.style.boxShadow = '0 0 6px rgba(239,68,68,0.5)';
                label.textContent = 'Unreachable';
                label.style.color = '#ef4444';
            }
        }
    })();
</script>
}
