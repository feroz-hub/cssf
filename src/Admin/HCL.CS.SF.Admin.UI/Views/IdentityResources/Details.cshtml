@model HCL.CS.SF.Admin.UI.Models.Api.IdentityResourcesModel

<!-- Page Header -->
<div class="hcl-page-header" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <div style="width: 56px; height: 56px; border-radius: 0.75rem; background: var(--hcl-bg-tertiary); display: flex; align-items: center; justify-content: center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28" style="color: var(--hcl-text-tertiary);"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
            <h1 class="hcl-page-title">
                <span class="hcl-gradient-text">@Model.Name</span>
            </h1>
            <p style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                @(Model.DisplayName ?? "Identity Resource")
                &middot;
                @if (Model.Enabled)
                {
                    <span class="hcl-badge hcl-badge-success">Enabled</span>
                }
                else
                {
                    <span class="hcl-badge hcl-badge-danger">Disabled</span>
                }
                @if (Model.Required)
                {
                    <span class="hcl-badge hcl-badge-warning">Required</span>
                }
                @if (Model.Emphasize)
                {
                    <span class="hcl-badge" style="background: rgba(168,85,247,0.15); color: #a855f7;">Emphasize</span>
                }
            </p>
        </div>
    </div>
    <div class="hcl-page-actions">
        <a href="/Admin/IdentityResources" class="hcl-btn hcl-btn-sm" style="background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Identity Resources
        </a>
    </div>
</div>

<!-- Editable Form -->
<div class="hcl-card hcl-glass" style="margin-bottom: 1.5rem;">
    <div style="padding: 1.5rem;">
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">Resource Settings</h3>
        <form id="identityResourceForm" onsubmit="return false;">
            <div class="hcl-grid hcl-grid-2">
                <div class="hcl-form-group">
                    <label class="hcl-label">Name <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="idr_name" value="@Model.Name" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Display Name</label>
                    <input type="text" class="hcl-input" id="idr_displayName" value="@Model.DisplayName" />
                </div>
            </div>
            <div class="hcl-form-group">
                <label class="hcl-label">Description</label>
                <input type="text" class="hcl-input" id="idr_description" value="@Model.Description" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.5rem;">
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Enabled</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Allow this identity resource to be requested</div>
                    </div>
                    <label class="hcl-toggle-switch">
                        <input type="checkbox" id="idr_enabled" @(Model.Enabled ? "checked" : "") />
                        <span></span>
                    </label>
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Required</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">User cannot deselect this scope on consent screen</div>
                    </div>
                    <label class="hcl-checkbox" style="margin: 0;"><input type="checkbox" id="idr_required" @(Model.Required ? "checked" : "") /></label>
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Emphasize</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Highlight this scope on the consent screen</div>
                    </div>
                    <label class="hcl-checkbox" style="margin: 0;"><input type="checkbox" id="idr_emphasize" @(Model.Emphasize ? "checked" : "") /></label>
                </div>
            </div>
            <div style="display: flex; justify-content: flex-end; margin-top: 1.25rem;">
                <button class="hcl-btn hcl-btn-primary" onclick="saveIdentityResource()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Claims Section -->
<div class="hcl-card hcl-glass">
    <div style="padding: 1.5rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
            <h3 style="font-size: 1rem; font-weight: 600; color: var(--hcl-text-primary);">
                Identity Claims
                <span class="hcl-badge hcl-badge-primary" style="margin-left: 0.5rem;">@(Model.IdentityClaims?.Count ?? 0)</span>
            </h3>
        </div>

        <!-- Claims Table -->
        <div class="hcl-table-wrapper" style="margin-bottom: 1.5rem;">
            <table class="hcl-table" id="claimsTable">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Alias Type</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.IdentityClaims == null || !Model.IdentityClaims.Any())
                    {
                        <tr id="noClaimsRow">
                            <td colspan="3">
                                <div class="hcl-empty-state" style="padding: 2rem 0;">
                                    <p style="color: var(--hcl-text-tertiary);">No claims configured. Add claims to define which user attributes this identity resource provides.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var claim in Model.IdentityClaims)
                        {
                            <tr data-claim-id="@claim.Id">
                                <td data-label="Type">
                                    <code style="font-size: 0.8rem; background: var(--hcl-bg-tertiary); padding: 0.125rem 0.375rem; border-radius: 0.25rem;">@claim.Type</code>
                                </td>
                                <td data-label="Alias Type" style="color: var(--hcl-text-secondary);">
                                    @if (!string.IsNullOrEmpty(claim.AliasType))
                                    {
                                        <code style="font-size: 0.8rem; background: var(--hcl-bg-tertiary); padding: 0.125rem 0.375rem; border-radius: 0.25rem;">@claim.AliasType</code>
                                    }
                                    else
                                    {
                                        <span style="color: var(--hcl-text-tertiary);">—</span>
                                    }
                                </td>
                                <td data-label="Actions" style="text-align: right;">
                                    <button class="hcl-btn hcl-btn-sm hcl-btn-danger" onclick="removeClaim('@claim.Id', '@claim.Type')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Add Claim -->
        <div style="border-top: 1px solid var(--hcl-border); padding-top: 1.25rem;">
            <label class="hcl-label" style="margin-bottom: 0.75rem;">Add Identity Claim</label>
            <div class="hcl-grid hcl-grid-3" style="align-items: flex-end;">
                <div class="hcl-form-group" style="margin-bottom: 0;">
                    <label class="hcl-label" style="font-size: 0.775rem;">Claim Type <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="newClaimType" placeholder="e.g. sub, email, name" />
                </div>
                <div class="hcl-form-group" style="margin-bottom: 0;">
                    <label class="hcl-label" style="font-size: 0.775rem;">Alias Type</label>
                    <input type="text" class="hcl-input" id="newClaimAliasType" placeholder="Optional alias" />
                </div>
                <div>
                    <button class="hcl-btn hcl-btn-primary hcl-btn-sm" onclick="addClaim()" style="width: 100%;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Claim
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var resourceId = '@Model.Id';

    function handleResult(result, successMsg) {
        if (result.success) {
            HCL.toastSuccess(successMsg);
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Operation failed.';
            HCL.toastError(msg);
        }
    }

    function collectClaims() {
        var claims = [];
        document.querySelectorAll('#claimsTable tbody tr[data-claim-id]').forEach(function(row) {
            var codes = row.querySelectorAll('code');
            var type = codes[0] ? codes[0].textContent.trim() : '';
            var aliasType = codes[1] ? codes[1].textContent.trim() : null;
            if (type) {
                claims.push({
                    id: row.getAttribute('data-claim-id'),
                    identityResourceId: resourceId,
                    type: type,
                    aliasType: aliasType
                });
            }
        });
        return claims;
    }

    function buildPayload(claims) {
        return {
            id: resourceId,
            name: document.getElementById('idr_name').value.trim(),
            displayName: document.getElementById('idr_displayName').value.trim() || null,
            description: document.getElementById('idr_description').value.trim() || null,
            enabled: document.getElementById('idr_enabled').checked,
            required: document.getElementById('idr_required').checked,
            emphasize: document.getElementById('idr_emphasize').checked,
            identityClaims: claims
        };
    }

    async function saveIdentityResource() {
        var name = document.getElementById('idr_name').value.trim();
        if (!name) {
            HCL.toastError('Resource name is required.');
            return;
        }
        try {
            var claims = collectClaims();
            var result = await HCL.apiRequest('/Admin/IdentityResources/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildPayload(claims))
            });
            handleResult(result, 'Identity resource saved successfully.');
        } catch (err) {
            HCL.toastError('An error occurred while saving.');
        }
    }

    async function addClaim() {
        var claimType = document.getElementById('newClaimType').value.trim();
        if (!claimType) {
            HCL.toastError('Claim type is required.');
            return;
        }
        var aliasType = document.getElementById('newClaimAliasType').value.trim() || null;

        try {
            var claims = collectClaims();
            claims.push({
                identityResourceId: resourceId,
                type: claimType,
                aliasType: aliasType
            });

            var result = await HCL.apiRequest('/Admin/IdentityResources/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildPayload(claims))
            });

            if (result.success) {
                HCL.toastSuccess('Claim added successfully.');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                handleResult(result, '');
            }
        } catch (err) {
            HCL.toastError('An error occurred while adding the claim.');
        }
    }

    async function removeClaim(claimId, claimType) {
        var ok = await HCL.confirm('Remove Claim', 'Remove claim type "' + claimType + '" from this identity resource?');
        if (!ok) return;

        try {
            var claims = collectClaims().filter(function(c) { return c.id !== claimId; });

            var result = await HCL.apiRequest('/Admin/IdentityResources/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildPayload(claims))
            });

            if (result.success) {
                HCL.toastSuccess('Claim removed successfully.');
                var row = document.querySelector('tr[data-claim-id="' + claimId + '"]');
                if (row) row.remove();
                if (document.querySelectorAll('#claimsTable tbody tr[data-claim-id]').length === 0) {
                    var tbody = document.querySelector('#claimsTable tbody');
                    tbody.innerHTML = '<tr id="noClaimsRow"><td colspan="3"><div class="hcl-empty-state" style="padding: 2rem 0;"><p style="color: var(--hcl-text-tertiary);">No claims configured.</p></div></td></tr>';
                }
            } else {
                handleResult(result, '');
            }
        } catch (err) {
            HCL.toastError('An error occurred while removing the claim.');
        }
    }
</script>
}
