@model List<HCL.CS.SF.Admin.UI.Models.Api.IdentityResourcesModel>

@{
    var resources = Model ?? new List<HCL.CS.SF.Admin.UI.Models.Api.IdentityResourcesModel>();
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">Identity Resources</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            @resources.Count identity resources configured
        </p>
    </div>
    <div class="hcl-page-actions">
        <button class="hcl-btn hcl-btn-primary" onclick="HCL.openModal('addIdentityResourceModal')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Resource
        </button>
    </div>
</div>

<!-- Search Bar -->
<div class="hcl-search-bar" style="margin-bottom: 1.5rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: var(--hcl-text-tertiary);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="hcl-search-input" id="identitySearchInput" placeholder="Search identity resources..." oninput="filterIdentityResources(this.value)" />
</div>

<!-- Card Grid -->
@if (!resources.Any())
{
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <p style="color: var(--hcl-text-tertiary);">No identity resources found. Add your first identity resource to get started.</p>
            <button class="hcl-btn hcl-btn-primary hcl-btn-sm" style="margin-top: 1rem;" onclick="HCL.openModal('addIdentityResourceModal')">Add Resource</button>
        </div>
    </div>
}
else
{
    <div class="hcl-grid hcl-grid-3" id="identityResourcesGrid">
        @foreach (var resource in resources)
        {
            var claimCount = resource.IdentityClaims?.Count ?? 0;

            <div class="hcl-card hcl-glass hcl-hover-lift identity-resource-card" data-name="@resource.Name.ToLower()">
                <div style="padding: 1.5rem;">
                    <!-- Card Header -->
                    <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
                        <div style="width: 40px; height: 40px; border-radius: 0.5rem; background: var(--hcl-bg-tertiary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="color: var(--hcl-text-tertiary);"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div style="display: flex; gap: 0.375rem; flex-wrap: wrap; justify-content: flex-end;">
                            @if (resource.Enabled)
                            {
                                <span class="hcl-badge hcl-badge-success">Enabled</span>
                            }
                            else
                            {
                                <span class="hcl-badge hcl-badge-danger">Disabled</span>
                            }
                            @if (resource.Required)
                            {
                                <span class="hcl-badge hcl-badge-warning">Required</span>
                            }
                            @if (resource.Emphasize)
                            {
                                <span class="hcl-badge" style="background: rgba(168,85,247,0.15); color: #a855f7;">Emphasize</span>
                            }
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div style="margin-bottom: 1rem;">
                        <h3 style="font-weight: 600; color: var(--hcl-text-primary); font-size: 1rem; margin-bottom: 0.25rem;">@resource.Name</h3>
                        @if (!string.IsNullOrEmpty(resource.DisplayName))
                        {
                            <p style="font-size: 0.8rem; color: var(--hcl-text-secondary); margin-bottom: 0.25rem;">@resource.DisplayName</p>
                        }
                        @if (!string.IsNullOrEmpty(resource.Description))
                        {
                            <p style="font-size: 0.775rem; color: var(--hcl-text-tertiary); line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@resource.Description</p>
                        }
                    </div>

                    <!-- Claim Count -->
                    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                        <span class="hcl-badge hcl-badge-primary">@claimCount claim@(claimCount != 1 ? "s" : "")</span>
                    </div>

                    <!-- Card Actions -->
                    <div style="display: flex; gap: 0.5rem; border-top: 1px solid var(--hcl-border); padding-top: 1rem;">
                        <a href="/Admin/IdentityResources/@resource.Id" class="hcl-btn hcl-btn-sm" style="flex: 1; background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border); justify-content: center;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            View
                        </a>
                        <button class="hcl-btn hcl-btn-danger hcl-btn-sm" onclick="deleteIdentityResource('@resource.Id', '@resource.Name')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Add Identity Resource Modal -->
<div class="hcl-modal-backdrop" id="addIdentityResourceModal">
    <div class="hcl-modal" style="max-width: 540px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Add Identity Resource
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('addIdentityResourceModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="addIdentityResourceForm" onsubmit="return false;">
                <div class="hcl-form-group">
                    <label class="hcl-label">Name <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="idr_name" required placeholder="e.g. openid, profile, email" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Display Name</label>
                    <input type="text" class="hcl-input" id="idr_displayName" placeholder="User Profile" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Description</label>
                    <input type="text" class="hcl-input" id="idr_description" placeholder="Optional description" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.5rem;">
                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                        <div>
                            <div style="font-weight: 500; font-size: 0.875rem; color: var(--hcl-text-primary);">Enabled</div>
                        </div>
                        <label class="hcl-checkbox" style="margin: 0;"><input type="checkbox" id="idr_enabled" checked /></label>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                        <div>
                            <div style="font-weight: 500; font-size: 0.875rem; color: var(--hcl-text-primary);">Required</div>
                            <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">User cannot deselect on consent screen</div>
                        </div>
                        <label class="hcl-checkbox" style="margin: 0;"><input type="checkbox" id="idr_required" /></label>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                        <div>
                            <div style="font-weight: 500; font-size: 0.875rem; color: var(--hcl-text-primary);">Emphasize</div>
                            <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">Highlight on consent screen</div>
                        </div>
                        <label class="hcl-checkbox" style="margin: 0;"><input type="checkbox" id="idr_emphasize" /></label>
                    </div>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('addIdentityResourceModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="addIdentityResourceBtn" onclick="createIdentityResource()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Resource
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterIdentityResources(query) {
        var q = query.toLowerCase().trim();
        var cards = document.querySelectorAll('.identity-resource-card');
        cards.forEach(function(card) {
            var name = card.getAttribute('data-name') || '';
            card.style.display = (!q || name.indexOf(q) !== -1) ? '' : 'none';
        });
    }

    async function createIdentityResource() {
        var name = document.getElementById('idr_name').value.trim();
        if (!name) {
            HCL.toastError('Resource name is required.');
            return;
        }

        var btn = document.getElementById('addIdentityResourceBtn');
        btn.disabled = true;
        btn.textContent = 'Adding...';

        try {
            var result = await HCL.apiRequest('/Admin/IdentityResources/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: name,
                    displayName: document.getElementById('idr_displayName').value.trim() || null,
                    description: document.getElementById('idr_description').value.trim() || null,
                    enabled: document.getElementById('idr_enabled').checked,
                    required: document.getElementById('idr_required').checked,
                    emphasize: document.getElementById('idr_emphasize').checked
                })
            });

            if (result.success) {
                HCL.toastSuccess('Identity resource added successfully.');
                HCL.closeModal('addIdentityResourceModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Failed to add identity resource.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred while adding the identity resource.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add Resource';
        }
    }

    async function deleteIdentityResource(resourceId, resourceName) {
        var ok = await HCL.confirm('Delete Identity Resource', 'Are you sure you want to permanently delete identity resource "' + resourceName + '"? All associated claims will also be removed. This action cannot be undone.');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/IdentityResources/Delete/' + resourceId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('Identity resource deleted successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Failed to delete identity resource.';
            HCL.toastError(msg);
        }
    }
</script>
}
