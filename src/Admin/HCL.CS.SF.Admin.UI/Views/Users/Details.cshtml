@model HCL.CS.SF.Admin.UI.Models.Api.UserModel

@{
    var userRoles = ViewBag.UserRoles as List<HCL.CS.SF.Admin.UI.Models.Api.RoleModel> ?? new();
    var userClaims = ViewBag.UserClaims as List<HCL.CS.SF.Admin.UI.Models.Api.UserClaimModel> ?? new();
    var allRoles = ViewBag.AllRoles as List<HCL.CS.SF.Admin.UI.Models.Api.RoleModel> ?? new();

    var isLocked = Model.LockoutEnd != null && Model.LockoutEnd > DateTimeOffset.UtcNow;
    var assignedRoleIds = userRoles.Select(r => r.Id).ToHashSet();
    var availableRoles = allRoles.Where(r => !assignedRoleIds.Contains(r.Id)).ToList();
    var initials = (Model.UserName?.Substring(0, 1) ?? "?").ToUpper();
}

<!-- Page Header -->
<div class="hcl-page-header" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <div class="hcl-avatar" style="width: 56px; height: 56px; font-size: 1.5rem;">
            <span>@initials</span>
        </div>
        <div>
            <h1 class="hcl-page-title">
                <span class="hcl-gradient-text">@Model.UserName</span>
            </h1>
            <p style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                @(Model.Email ?? "No email") &middot;
                @if (isLocked)
                {
                    <span style="color: #ef4444;">Locked</span>
                }
                else
                {
                    <span style="color: #22c55e;">Active</span>
                }
            </p>
        </div>
    </div>
    <div class="hcl-page-actions">
        <a href="/Admin/Users" class="hcl-btn hcl-btn-sm" style="background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Users
        </a>
    </div>
</div>

<!-- Tabs -->
<div class="hcl-tabs" style="margin-bottom: 1.5rem;">
    <button class="hcl-tab active" onclick="switchTab('profile', this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
    </button>
    <button class="hcl-tab" onclick="switchTab('roles', this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Roles <span class="hcl-badge" style="margin-left: 0.375rem; font-size: 0.7rem;">@userRoles.Count</span>
    </button>
    <button class="hcl-tab" onclick="switchTab('claims', this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        Claims <span class="hcl-badge" style="margin-left: 0.375rem; font-size: 0.7rem;">@userClaims.Count</span>
    </button>
    <button class="hcl-tab" onclick="switchTab('security', this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Security
    </button>
</div>

<!-- Tab: Profile -->
<div class="tab-panel" id="tab-profile">
    <div class="hcl-card hcl-glass">
        <div style="padding: 1.5rem;">
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                Edit Profile
            </h3>
            <form id="profileForm" onsubmit="return false;">
                <input type="hidden" id="profile_id" value="@Model.Id" />
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">Username</label>
                        <input type="text" class="hcl-input" id="profile_userName" value="@Model.UserName" readonly style="opacity: 0.6; cursor: not-allowed;" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Email</label>
                        <input type="email" class="hcl-input" id="profile_email" value="@Model.Email" />
                    </div>
                </div>
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">First Name</label>
                        <input type="text" class="hcl-input" id="profile_firstName" value="@Model.FirstName" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Last Name</label>
                        <input type="text" class="hcl-input" id="profile_lastName" value="@Model.LastName" />
                    </div>
                </div>
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">Phone Number</label>
                        <input type="tel" class="hcl-input" id="profile_phone" value="@Model.PhoneNumber" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Date of Birth</label>
                        <input type="date" class="hcl-input" id="profile_dob" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                    </div>
                </div>
                <div style="display: flex; justify-content: flex-end; margin-top: 1rem;">
                    <button class="hcl-btn hcl-btn-primary" onclick="updateProfile()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tab: Roles -->
<div class="tab-panel" id="tab-roles" style="display: none;">
    <div class="hcl-grid hcl-grid-2">
        <!-- Assigned Roles -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    Assigned Roles
                </h3>
                <div id="assignedRolesList">
                    @if (userRoles.Any())
                    {
                        foreach (var role in userRoles)
                        {
                            <div class="role-item" id="role-@role.Id" style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.5rem;">
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <div style="width: 8px; height: 8px; border-radius: 50%; background: linear-gradient(135deg, #a855f7, #ec4899);"></div>
                                    <span style="font-weight: 500; color: var(--hcl-text-primary);">@role.Name</span>
                                    <span class="hcl-badge" style="font-size: 0.7rem;">@role.RoleClaims.Count claims</span>
                                </div>
                                <button class="hcl-btn hcl-btn-danger hcl-btn-sm" onclick="removeRole('@Model.Id', '@role.Id', '@role.Name')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    Remove
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="hcl-empty-state" style="padding: 2rem 0;">
                            <p style="color: var(--hcl-text-tertiary); font-size: 0.875rem;">No roles assigned to this user.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Add Role -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    Add Role
                </h3>
                @if (availableRoles.Any())
                {
                    <div class="hcl-form-group">
                        <label class="hcl-label">Select Role</label>
                        <select class="hcl-input" id="addRoleSelect">
                            <option value="">-- Select a role --</option>
                            @foreach (var role in availableRoles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        </select>
                    </div>
                    <button class="hcl-btn hcl-btn-primary hcl-btn-sm" onclick="addRole('@Model.Id')" style="margin-top: 0.5rem;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Assign Role
                    </button>
                }
                else
                {
                    <div class="hcl-empty-state" style="padding: 2rem 0;">
                        <p style="color: var(--hcl-text-tertiary); font-size: 0.875rem;">All available roles are already assigned.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Tab: Claims -->
<div class="tab-panel" id="tab-claims" style="display: none;">
    <div class="hcl-grid hcl-grid-2">
        <!-- Existing Claims -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    User Claims
                </h3>
                <div id="claimsList">
                    @if (userClaims.Any())
                    {
                        <div class="hcl-table-wrapper">
                            <table class="hcl-table">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Value</th>
                                        <th style="text-align: right;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var claim in userClaims)
                                    {
                                        <tr id="claim-@claim.Id">
                                            <td data-label="Type">
                                                <span style="font-weight: 500; color: var(--hcl-text-primary);">@claim.ClaimType</span>
                                            </td>
                                            <td data-label="Value" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                                                @claim.ClaimValue
                                            </td>
                                            <td data-label="Actions" style="text-align: right;">
                                                <button class="hcl-btn hcl-btn-danger hcl-btn-sm"
                                                        onclick="removeClaim('@claim.Id', '@claim.UserId', '@claim.ClaimType', '@claim.ClaimValue')">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="hcl-empty-state" style="padding: 2rem 0;">
                            <p style="color: var(--hcl-text-tertiary); font-size: 0.875rem;">No claims assigned to this user.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Add Claim -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    Add Claim
                </h3>
                <div class="hcl-form-group">
                    <label class="hcl-label">Claim Type <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="addClaimType" placeholder="e.g. permission, role, scope" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Claim Value <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="addClaimValue" placeholder="e.g. admin, read, write" />
                </div>
                <button class="hcl-btn hcl-btn-primary hcl-btn-sm" onclick="addClaim('@Model.Id')" style="margin-top: 0.5rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Claim
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tab: Security -->
<div class="tab-panel" id="tab-security" style="display: none;">
    <div class="hcl-grid hcl-grid-2">
        <!-- Account Status -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    Account Status
                </h3>

                <!-- Lock Status -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Account Lock</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">
                            @if (isLocked)
                            {
                                <span>Locked until @Model.LockoutEnd?.ToString("g")</span>
                            }
                            else
                            {
                                <span>Account is active and unlocked</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (isLocked)
                        {
                            <button class="hcl-btn hcl-btn-sm" style="background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3);"
                                    onclick="securityUnlockUser('@Model.UserName')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                Unlock
                            </button>
                        }
                        else
                        {
                            <button class="hcl-btn hcl-btn-sm" style="background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3);"
                                    onclick="securityLockUser('@Model.Id')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                Lock
                            </button>
                        }
                    </div>
                </div>

                <!-- Email Confirmation -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Email Confirmed</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">@(Model.Email ?? "N/A")</div>
                    </div>
                    @if (Model.EmailConfirmed)
                    {
                        <span class="hcl-badge" style="background: rgba(34,197,94,0.15); color: #22c55e;">Confirmed</span>
                    }
                    else
                    {
                        <span class="hcl-badge" style="background: rgba(234,179,8,0.15); color: #eab308;">Unconfirmed</span>
                    }
                </div>

                <!-- Phone Confirmation -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Phone Confirmed</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">@(Model.PhoneNumber ?? "N/A")</div>
                    </div>
                    @if (Model.PhoneNumberConfirmed)
                    {
                        <span class="hcl-badge" style="background: rgba(34,197,94,0.15); color: #22c55e;">Confirmed</span>
                    }
                    else
                    {
                        <span class="hcl-badge" style="background: rgba(234,179,8,0.15); color: #eab308;">Unconfirmed</span>
                    }
                </div>
            </div>
        </div>

        <!-- Security Details -->
        <div class="hcl-card hcl-glass">
            <div style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--hcl-text-primary);">
                    Security Details
                </h3>

                <!-- 2FA Status -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Two-Factor Authentication</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">
                            @(Model.TwoFactorType ?? "Not configured")
                        </div>
                    </div>
                    @if (Model.TwoFactorEnabled)
                    {
                        <span class="hcl-badge" style="background: rgba(34,197,94,0.15); color: #22c55e;">
                            <span class="hcl-pulse-dot" style="--dot-color: #22c55e;"></span> Enabled
                        </span>
                    }
                    else
                    {
                        <span class="hcl-badge" style="background: rgba(107,114,128,0.15); color: #6b7280;">Disabled</span>
                    }
                </div>

                <!-- Access Failed Count -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Failed Login Attempts</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Since last successful login</div>
                    </div>
                    <span class="hcl-badge" style="background: @(Model.AccessFailedCount > 0 ? "rgba(239,68,68,0.15)" : "rgba(107,114,128,0.15)"); color: @(Model.AccessFailedCount > 0 ? "#ef4444" : "#6b7280");">
                        @Model.AccessFailedCount
                    </span>
                </div>

                <!-- Last Login -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Last Login</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">
                            @if (Model.LastLoginDateTime.HasValue)
                            {
                                @Model.LastLoginDateTime.Value.ToString("g")
                            }
                            else
                            {
                                <span>Never logged in</span>
                            }
                        </div>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--hcl-text-tertiary)" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>

                <!-- Last Password Change -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem; margin-bottom: 0.75rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Last Password Change</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">
                            @if (Model.LastPasswordChangedDate.HasValue)
                            {
                                @Model.LastPasswordChangedDate.Value.ToString("g")
                            }
                            else
                            {
                                <span>Never changed</span>
                            }
                        </div>
                    </div>
                    @if (Model.RequiresDefaultPasswordChange)
                    {
                        <span class="hcl-badge" style="background: rgba(239,68,68,0.15); color: #ef4444;">Must Change</span>
                    }
                </div>

                <!-- Identity Provider -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Identity Provider</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Authentication source</div>
                    </div>
                    <span class="hcl-badge">@(Model.IdentityProviderType ?? "Local")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Metadata -->
    <div class="hcl-card hcl-glass" style="margin-top: 1rem;">
        <div style="padding: 1.5rem;">
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--hcl-text-primary);">Metadata</h3>
            <div class="hcl-grid hcl-grid-3">
                <div style="padding: 0.75rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">User ID</div>
                    <div style="font-size: 0.8rem; font-weight: 500; color: var(--hcl-text-primary); word-break: break-all; cursor: pointer;" onclick="HCL.copyToClipboard('@Model.Id')" title="Click to copy">
                        @Model.Id
                    </div>
                </div>
                <div style="padding: 0.75rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">Created</div>
                    <div style="font-size: 0.8rem; font-weight: 500; color: var(--hcl-text-primary);">
                        @(Model.CreatedOn?.ToString("g") ?? "Unknown")
                    </div>
                </div>
                <div style="padding: 0.75rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">Last Modified</div>
                    <div style="font-size: 0.8rem; font-weight: 500; color: var(--hcl-text-primary);">
                        @(Model.ModifiedOn?.ToString("g") ?? "Unknown")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function switchTab(tabId, btn) {
        // Hide all panels
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.style.display = 'none'; });
        // Deactivate all tabs
        document.querySelectorAll('.hcl-tab').forEach(function(t) { t.classList.remove('active'); });
        // Show selected panel and activate tab
        document.getElementById('tab-' + tabId).style.display = 'block';
        btn.classList.add('active');
    }

    async function updateProfile() {
        var payload = {
            id: document.getElementById('profile_id').value,
            userName: document.getElementById('profile_userName').value,
            email: document.getElementById('profile_email').value.trim() || null,
            firstName: document.getElementById('profile_firstName').value.trim() || null,
            lastName: document.getElementById('profile_lastName').value.trim() || null,
            phoneNumber: document.getElementById('profile_phone').value.trim() || null,
            dateOfBirth: document.getElementById('profile_dob').value || null
        };

        var result = await HCL.apiRequest('/Admin/Users/Update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        if (result.success) {
            HCL.toastSuccess('Profile updated successfully.');
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Failed to update profile.';
            HCL.toastError(msg);
        }
    }

    async function addRole(userId) {
        var roleId = document.getElementById('addRoleSelect').value;
        if (!roleId) {
            HCL.toastError('Please select a role.');
            return;
        }
        var result = await HCL.apiRequest('/Admin/Users/AddRole', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId, roleId: roleId })
        });
        if (result.success) {
            HCL.toastSuccess('Role assigned successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to assign role.');
        }
    }

    async function removeRole(userId, roleId, roleName) {
        var ok = await HCL.confirm('Remove Role', 'Remove role "' + roleName + '" from this user?');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/RemoveRole', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId, roleId: roleId })
        });
        if (result.success) {
            HCL.toastSuccess('Role removed successfully.');
            var el = document.getElementById('role-' + roleId);
            if (el) el.remove();
        } else {
            HCL.toastError('Failed to remove role.');
        }
    }

    async function addClaim(userId) {
        var claimType = document.getElementById('addClaimType').value.trim();
        var claimValue = document.getElementById('addClaimValue').value.trim();
        if (!claimType || !claimValue) {
            HCL.toastError('Claim type and value are required.');
            return;
        }
        var result = await HCL.apiRequest('/Admin/Users/AddClaim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId, claimType: claimType, claimValue: claimValue })
        });
        if (result.success) {
            HCL.toastSuccess('Claim added successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to add claim.');
        }
    }

    async function removeClaim(claimId, userId, claimType, claimValue) {
        var ok = await HCL.confirm('Remove Claim', 'Remove claim "' + claimType + ': ' + claimValue + '"?');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/RemoveClaim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: claimId, userId: userId, claimType: claimType, claimValue: claimValue })
        });
        if (result.success) {
            HCL.toastSuccess('Claim removed successfully.');
            var el = document.getElementById('claim-' + claimId);
            if (el) el.remove();
        } else {
            HCL.toastError('Failed to remove claim.');
        }
    }

    async function securityLockUser(userId) {
        var ok = await HCL.confirm('Lock User', 'Are you sure you want to lock this user account?');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/Lock/' + userId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('User locked successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to lock user.');
        }
    }

    async function securityUnlockUser(userName) {
        var ok = await HCL.confirm('Unlock User', 'Are you sure you want to unlock this user account?');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/Unlock', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(userName)
        });
        if (result.success) {
            HCL.toastSuccess('User unlocked successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to unlock user.');
        }
    }
</script>
}
