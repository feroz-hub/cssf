@model List<HCL.CS.SF.Admin.UI.Models.Api.UserDisplayModel>

@{
    var users = Model ?? new List<HCL.CS.SF.Admin.UI.Models.Api.UserDisplayModel>();
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">Users</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            @users.Count registered identities
        </p>
    </div>
    <div class="hcl-page-actions">
        <button class="hcl-btn hcl-btn-primary" onclick="HCL.openModal('registerUserModal')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Register User
        </button>
    </div>
</div>

<!-- Search Bar -->
<div class="hcl-search-bar" style="margin-bottom: 1.5rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: var(--hcl-text-tertiary);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="hcl-search-input" id="userSearchInput" placeholder="Search users by name, email, or phone..." oninput="filterUsers(this.value)" />
</div>

<!-- Users Table -->
<div class="hcl-card hcl-glass">
    <div class="hcl-table-wrapper">
        <table class="hcl-table" id="usersTable">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!users.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="hcl-empty-state" style="padding: 3rem 0;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                                <p style="color: var(--hcl-text-tertiary);">No users found. Register your first user to get started.</p>
                                <button class="hcl-btn hcl-btn-primary hcl-btn-sm" style="margin-top: 1rem;" onclick="HCL.openModal('registerUserModal')">Register User</button>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var user in users)
                {
                    var isLocked = user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow;
                    var initials = (user.UserName?.Substring(0, 1) ?? "?").ToUpper();
                    <tr class="user-row"
                        data-username="@user.UserName?.ToLower()"
                        data-email="@user.Email?.ToLower()"
                        data-phone="@user.PhoneNumber?.ToLower()"
                        data-fullname="@((user.FirstName ?? "").ToLower()) @((user.LastName ?? "").ToLower())">
                        <td data-label="User">
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <div class="hcl-avatar hcl-avatar-sm">
                                    <span>@initials</span>
                                </div>
                                <div>
                                    <div style="font-weight: 500; color: var(--hcl-text-primary);">@user.UserName</div>
                                    <div style="font-size: 0.75rem; color: var(--hcl-text-tertiary);">
                                        @(user.FirstName ?? "") @(user.LastName ?? "")
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Email" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                            @(user.Email ?? "N/A")
                        </td>
                        <td data-label="Phone" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                            @(user.PhoneNumber ?? "N/A")
                        </td>
                        <td data-label="Status">
                            @if (isLocked)
                            {
                                <span class="hcl-badge" style="background: rgba(239,68,68,0.15); color: #ef4444;">
                                    <span class="hcl-pulse-dot" style="--dot-color: #ef4444;"></span> Locked
                                </span>
                            }
                            else if (!user.LockoutEnabled)
                            {
                                <span class="hcl-badge" style="background: rgba(234,179,8,0.15); color: #eab308;">
                                    Lockout Disabled
                                </span>
                            }
                            else
                            {
                                <span class="hcl-badge" style="background: rgba(34,197,94,0.15); color: #22c55e;">
                                    <span class="hcl-pulse-dot" style="--dot-color: #22c55e;"></span> Active
                                </span>
                            }
                        </td>
                        <td data-label="Actions" style="text-align: right;">
                            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <a href="/Admin/Users/@user.Id" class="hcl-btn hcl-btn-sm" style="background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    View
                                </a>
                                @if (isLocked)
                                {
                                    <button class="hcl-btn hcl-btn-sm" style="background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3);"
                                            onclick="unlockUser('@user.UserName')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                        Unlock
                                    </button>
                                }
                                else
                                {
                                    <button class="hcl-btn hcl-btn-sm" style="background: rgba(234,179,8,0.15); color: #eab308; border: 1px solid rgba(234,179,8,0.3);"
                                            onclick="lockUser('@user.Id')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        Lock
                                    </button>
                                }
                                <button class="hcl-btn hcl-btn-danger hcl-btn-sm" onclick="deleteUser('@user.Id', '@user.UserName')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Register User Modal -->
<div class="hcl-modal-backdrop" id="registerUserModal">
    <div class="hcl-modal">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                Register New User
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('registerUserModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="registerUserForm" onsubmit="return false;">
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">Username <span style="color: #ef4444;">*</span></label>
                        <input type="text" class="hcl-input" id="reg_userName" required placeholder="Enter username" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Password <span style="color: #ef4444;">*</span></label>
                        <input type="password" class="hcl-input" id="reg_password" required placeholder="Enter password" />
                    </div>
                </div>
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">First Name</label>
                        <input type="text" class="hcl-input" id="reg_firstName" placeholder="Enter first name" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Last Name</label>
                        <input type="text" class="hcl-input" id="reg_lastName" placeholder="Enter last name" />
                    </div>
                </div>
                <div class="hcl-grid hcl-grid-2">
                    <div class="hcl-form-group">
                        <label class="hcl-label">Email <span style="color: #ef4444;">*</span></label>
                        <input type="email" class="hcl-input" id="reg_email" required placeholder="user@example.com" />
                    </div>
                    <div class="hcl-form-group">
                        <label class="hcl-label">Phone Number</label>
                        <input type="tel" class="hcl-input" id="reg_phone" placeholder="+1 (555) 000-0000" />
                    </div>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('registerUserModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="registerUserBtn" onclick="registerUser()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                Register User
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterUsers(query) {
        var q = query.toLowerCase().trim();
        var rows = document.querySelectorAll('.user-row');
        rows.forEach(function(row) {
            var username = row.getAttribute('data-username') || '';
            var email = row.getAttribute('data-email') || '';
            var phone = row.getAttribute('data-phone') || '';
            var fullname = row.getAttribute('data-fullname') || '';
            var match = !q || username.indexOf(q) !== -1 || email.indexOf(q) !== -1 || phone.indexOf(q) !== -1 || fullname.indexOf(q) !== -1;
            row.style.display = match ? '' : 'none';
        });
    }

    async function registerUser() {
        var userName = document.getElementById('reg_userName').value.trim();
        var password = document.getElementById('reg_password').value;
        var email = document.getElementById('reg_email').value.trim();

        if (!userName || !password || !email) {
            HCL.toastError('Username, password, and email are required.');
            return;
        }

        var btn = document.getElementById('registerUserBtn');
        btn.disabled = true;
        btn.textContent = 'Registering...';

        try {
            var result = await HCL.apiRequest('/Admin/Users/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    userName: userName,
                    password: password,
                    firstName: document.getElementById('reg_firstName').value.trim() || null,
                    lastName: document.getElementById('reg_lastName').value.trim() || null,
                    email: email,
                    phoneNumber: document.getElementById('reg_phone').value.trim() || null
                })
            });

            if (result.success) {
                HCL.toastSuccess('User registered successfully.');
                HCL.closeModal('registerUserModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Registration failed.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred during registration.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg> Register User';
        }
    }

    async function lockUser(userId) {
        var ok = await HCL.confirm('Lock User', 'Are you sure you want to lock this user account? They will be unable to sign in.');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/Lock/' + userId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('User locked successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to lock user.');
        }
    }

    async function unlockUser(userName) {
        var ok = await HCL.confirm('Unlock User', 'Are you sure you want to unlock this user account?');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/Unlock', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(userName)
        });
        if (result.success) {
            HCL.toastSuccess('User unlocked successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to unlock user.');
        }
    }

    async function deleteUser(userId, userName) {
        var ok = await HCL.confirm('Delete User', 'Are you sure you want to permanently delete user "' + userName + '"? This action cannot be undone.');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Users/Delete/' + userId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('User deleted successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            HCL.toastError('Failed to delete user.');
        }
    }
</script>
}
