@model HCL.CS.SF.Admin.UI.Models.Api.ClientSecretsViewModel

@{
    var hasExpiry = Model.SecretExpiresAt.HasValue;
    var expiresText = hasExpiry ? Model.SecretExpiresAt.Value.ToString("g") : "Not available";
}

<!-- Page Header -->
<div class="hcl-page-header" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <div style="width: 56px; height: 56px; border-radius: 0.75rem; background: var(--hcl-bg-tertiary); display: flex; align-items: center; justify-content: center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28" style="color: var(--hcl-text-tertiary);">
                <path d="M12 1v6" />
                <path d="M9 9a3 3 0 0 1 6 0c0 2-3 2-3 5s0 3-3 3-3-1-3-3 0-4 3-5z" />
            </svg>
        </div>
        <div>
            <h1 class="hcl-page-title">
                <span class="hcl-gradient-text">Client Secrets</span>
            </h1>
            <p style="color: var(--hcl-text-secondary); font-size: 0.875rem; margin-top: 0.25rem;">
                @(Model.ClientName) &middot; @Model.ClientId
            </p>
        </div>
    </div>
    <div class="hcl-page-actions">
        <a href="/Admin/Clients" class="hcl-btn hcl-btn-sm" style="background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back
        </a>
    </div>
</div>

<!-- Current Secret Info -->
<div class="hcl-card hcl-glass">
    <div style="padding: 1.5rem;">
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--hcl-text-primary);">
            Primary Client Secret
        </h3>

        <div class="hcl-table-wrapper">
            <table class="hcl-table">
                <thead>
                    <tr>
                        <th>Secret Type</th>
                        <th>Status</th>
                        <th>Expires At</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Primary Client Secret</td>
                        <td>
                            <span class="hcl-badge" style="background: rgba(34,197,94,0.15); color: #22c55e;">
                                Active
                            </span>
                        </td>
                        <td style="color: var(--hcl-text-secondary); font-size: 0.875rem;">
                            @expiresText
                        </td>
                        <td style="text-align: right;">
                            <button class="hcl-btn hcl-btn-secondary hcl-btn-sm" onclick="generateNewSecret()">
                                Generate New Secret
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <p class="inline-message" style="margin-top: 0.75rem;">
            HCL.CS.SF API exposes one active secret. Rotation revokes the previous value automatically.
        </p>
    </div>
</div>

<!-- Generated Secret (shown once) -->
<div class="hcl-card hcl-glass" id="generatedSecretCard" style="display: none; margin-top: 1.25rem;">
    <div style="padding: 1.5rem; display: grid; gap: 0.9rem;">
        <p class="inline-message success" style="margin: 0;">
            Secret value shown once. Copy before dismissing.
        </p>
        <input class="hcl-input" id="generatedSecretInput" type="text" readonly />
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <button class="hcl-btn hcl-btn-secondary hcl-btn-sm" type="button" onclick="copyGeneratedSecret()">
                Copy Secret
            </button>
            <button class="hcl-btn hcl-btn-ghost hcl-btn-sm" type="button" onclick="dismissGeneratedSecret()">
                Dismiss
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function generateNewSecret() {
        const ok = await HCL.confirm(
            'Rotate client secret',
            'This will revoke the current secret and generate a new one. Copy the new value now before closing.'
        );

        if (!ok) return;

        try {
            const result = await HCL.apiRequest('/Admin/Clients/GenerateSecret/' + '@Model.ClientId', 'POST', null);

            if (!result.success) {
                HCL.toastError('Client secret rotation failed.');
                return;
            }

            const secret = result.data?.secret ?? null;
            if (!secret) {
                HCL.toastError('The server did not return the generated secret value.');
                return;
            }

            const card = document.getElementById('generatedSecretCard');
            const input = document.getElementById('generatedSecretInput');
            input.value = secret;
            card.style.display = '';

            HCL.toastSuccess('Client secret rotated. Copy the value now.');
        } catch (err) {
            HCL.toastError('An error occurred while rotating the client secret.');
        }
    }

    function dismissGeneratedSecret() {
        const card = document.getElementById('generatedSecretCard');
        card.style.display = 'none';

        const input = document.getElementById('generatedSecretInput');
        input.value = '';
    }

    function copyGeneratedSecret() {
        const input = document.getElementById('generatedSecretInput');
        const value = input.value || '';
        if (!value) return;

        HCL.copyToClipboard(value);
    }
</script>
}

