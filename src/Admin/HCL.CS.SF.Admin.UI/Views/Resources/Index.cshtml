@model List<HCL.CS.SF.Admin.UI.Models.Api.ApiResourcesModel>

@{
    var resources = Model ?? new List<HCL.CS.SF.Admin.UI.Models.Api.ApiResourcesModel>();
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">API Resources &amp; Scopes</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            @resources.Count registered API resources
        </p>
    </div>
    <div class="hcl-page-actions">
        <button class="hcl-btn hcl-btn-primary" onclick="HCL.openModal('addResourceModal')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Resource
        </button>
    </div>
</div>

<!-- Search Bar -->
<div class="hcl-search-bar" style="margin-bottom: 1.5rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: var(--hcl-text-tertiary);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="hcl-search-input" id="resourceSearchInput" placeholder="Search resources by name..." oninput="filterResources(this.value)" />
</div>

<!-- Resources Accordion -->
@if (!resources.Any())
{
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p style="color: var(--hcl-text-tertiary);">No API resources found. Add your first API resource to get started.</p>
            <button class="hcl-btn hcl-btn-primary hcl-btn-sm" style="margin-top: 1rem;" onclick="HCL.openModal('addResourceModal')">Add Resource</button>
        </div>
    </div>
}
else
{
    <div id="resourcesList">
        @foreach (var resource in resources)
        {
            var scopeCount = resource.ApiScopes?.Count ?? 0;

            <div class="hcl-card hcl-glass hcl-accordion resource-item" data-name="@resource.Name.ToLower()" style="margin-bottom: 0.75rem;">
                <!-- Accordion Header -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; cursor: pointer;" onclick="toggleAccordion(this)">
                    <div style="display: flex; align-items: center; gap: 1rem; flex: 1;">
                        <div style="width: 40px; height: 40px; border-radius: 0.5rem; background: var(--hcl-bg-tertiary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="color: var(--hcl-text-tertiary);"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <div>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-weight: 600; color: var(--hcl-text-primary); font-size: 0.95rem;">@resource.Name</span>
                                @if (resource.Enabled)
                                {
                                    <span class="hcl-badge hcl-badge-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="hcl-badge hcl-badge-danger">Disabled</span>
                                }
                                <span class="hcl-badge hcl-badge-primary">@scopeCount scope@(scopeCount != 1 ? "s" : "")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(resource.DisplayName))
                            {
                                <div style="font-size: 0.8rem; color: var(--hcl-text-secondary); margin-top: 0.125rem;">@resource.DisplayName</div>
                            }
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <a href="/Admin/Resources/@resource.Id" class="hcl-btn hcl-btn-sm hcl-btn-ghost" onclick="event.stopPropagation();" title="Edit Resource">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Edit
                        </a>
                        <button class="hcl-btn hcl-btn-sm hcl-btn-secondary" onclick="event.stopPropagation(); openAddScopeModal('@resource.Id', '@resource.Name')" title="Add Scope">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Scope
                        </button>
                        <button class="hcl-btn hcl-btn-sm hcl-btn-danger" onclick="event.stopPropagation(); deleteResource('@resource.Id', '@resource.Name')" title="Delete Resource">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="color: var(--hcl-text-tertiary); transition: transform 0.2s;" class="accordion-chevron"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                </div>

                <!-- Accordion Body: Scopes Table -->
                <div class="accordion-body" style="display: none; border-top: 1px solid var(--hcl-border); padding: 1rem 1.5rem;">
                    @if (scopeCount == 0)
                    {
                        <div style="text-align: center; padding: 1.5rem 0; color: var(--hcl-text-tertiary); font-size: 0.875rem;">
                            No scopes defined for this resource.
                            <button class="hcl-btn hcl-btn-sm hcl-btn-primary" style="margin-left: 0.5rem;" onclick="openAddScopeModal('@resource.Id', '@resource.Name')">Add Scope</button>
                        </div>
                    }
                    else
                    {
                        <div class="hcl-table-wrapper">
                            <table class="hcl-table">
                                <thead>
                                    <tr>
                                        <th>Scope Name</th>
                                        <th>Display Name</th>
                                        <th>Description</th>
                                        <th>Required</th>
                                        <th>Emphasize</th>
                                        <th style="text-align: right;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var scope in resource.ApiScopes)
                                    {
                                        <tr>
                                            <td data-label="Scope Name">
                                                <code style="font-size: 0.8rem; background: var(--hcl-bg-tertiary); padding: 0.125rem 0.375rem; border-radius: 0.25rem;">@scope.Name</code>
                                            </td>
                                            <td data-label="Display Name" style="color: var(--hcl-text-secondary);">@(scope.DisplayName ?? "—")</td>
                                            <td data-label="Description" style="color: var(--hcl-text-tertiary); font-size: 0.8rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@(scope.Description ?? "—")</td>
                                            <td data-label="Required">
                                                @if (scope.Required)
                                                {
                                                    <span class="hcl-badge hcl-badge-warning">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="hcl-badge">No</span>
                                                }
                                            </td>
                                            <td data-label="Emphasize">
                                                @if (scope.Emphasize)
                                                {
                                                    <span class="hcl-badge" style="background: rgba(168,85,247,0.15); color: #a855f7;">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="hcl-badge">No</span>
                                                }
                                            </td>
                                            <td data-label="Actions" style="text-align: right;">
                                                <div style="display: flex; gap: 0.375rem; justify-content: flex-end;">
                                                    <button class="hcl-btn hcl-btn-sm hcl-btn-ghost" onclick="openEditScopeModal('@scope.Id', '@scope.ApiResourceId', '@scope.Name', '@(scope.DisplayName ?? "")', '@(scope.Description ?? "")', @scope.Required.ToString().ToLower(), @scope.Emphasize.ToString().ToLower())">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                        Edit
                                                    </button>
                                                    <button class="hcl-btn hcl-btn-sm hcl-btn-danger" onclick="deleteScope('@scope.Id', '@scope.Name')">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Add Resource Modal -->
<div class="hcl-modal-backdrop" id="addResourceModal">
    <div class="hcl-modal" style="max-width: 540px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Add API Resource
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('addResourceModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="addResourceForm" onsubmit="return false;">
                <div class="hcl-form-group">
                    <label class="hcl-label">Name <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="res_name" required placeholder="my-api" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Display Name</label>
                    <input type="text" class="hcl-input" id="res_displayName" placeholder="My API" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Description</label>
                    <input type="text" class="hcl-input" id="res_description" placeholder="Optional description" />
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--hcl-bg-tertiary); border-radius: 0.5rem;">
                    <div>
                        <div style="font-weight: 500; color: var(--hcl-text-primary);">Enabled</div>
                        <div style="font-size: 0.8rem; color: var(--hcl-text-tertiary);">Allow this resource to be used</div>
                    </div>
                    <label class="hcl-toggle-switch">
                        <input type="checkbox" id="res_enabled" checked />
                        <span></span>
                    </label>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('addResourceModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="addResourceBtn" onclick="createResource()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Resource
            </button>
        </div>
    </div>
</div>

<!-- Add Scope Modal -->
<div class="hcl-modal-backdrop" id="addScopeModal">
    <div class="hcl-modal" style="max-width: 540px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Add Scope
            </h3>
            <span id="addScopeResourceLabel" style="font-size: 0.8rem; color: var(--hcl-text-tertiary);"></span>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('addScopeModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="addScopeForm" onsubmit="return false;">
                <input type="hidden" id="scope_resourceId" />
                <div class="hcl-form-group">
                    <label class="hcl-label">Scope Name <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="scope_name" required placeholder="read:items" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Display Name</label>
                    <input type="text" class="hcl-input" id="scope_displayName" placeholder="Read Items" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Description</label>
                    <input type="text" class="hcl-input" id="scope_description" placeholder="Optional description" />
                </div>
                <div style="display: flex; gap: 2rem; margin-top: 0.5rem;">
                    <label class="hcl-checkbox">
                        <input type="checkbox" id="scope_required" />
                        Required
                    </label>
                    <label class="hcl-checkbox">
                        <input type="checkbox" id="scope_emphasize" />
                        Emphasize
                    </label>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('addScopeModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="addScopeBtn" onclick="createScope()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Scope
            </button>
        </div>
    </div>
</div>

<!-- Edit Scope Modal -->
<div class="hcl-modal-backdrop" id="editScopeModal">
    <div class="hcl-modal" style="max-width: 540px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Scope
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('editScopeModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="editScopeForm" onsubmit="return false;">
                <input type="hidden" id="edit_scope_id" />
                <input type="hidden" id="edit_scope_resourceId" />
                <div class="hcl-form-group">
                    <label class="hcl-label">Scope Name <span style="color: #ef4444;">*</span></label>
                    <input type="text" class="hcl-input" id="edit_scope_name" required />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Display Name</label>
                    <input type="text" class="hcl-input" id="edit_scope_displayName" />
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Description</label>
                    <input type="text" class="hcl-input" id="edit_scope_description" />
                </div>
                <div style="display: flex; gap: 2rem; margin-top: 0.5rem;">
                    <label class="hcl-checkbox">
                        <input type="checkbox" id="edit_scope_required" />
                        Required
                    </label>
                    <label class="hcl-checkbox">
                        <input type="checkbox" id="edit_scope_emphasize" />
                        Emphasize
                    </label>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('editScopeModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="editScopeBtn" onclick="updateScope()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save Changes
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterResources(query) {
        var q = query.toLowerCase().trim();
        var items = document.querySelectorAll('.resource-item');
        items.forEach(function(item) {
            var name = item.getAttribute('data-name') || '';
            item.style.display = (!q || name.indexOf(q) !== -1) ? '' : 'none';
        });
    }

    function toggleAccordion(header) {
        var body = header.nextElementSibling;
        var chevron = header.querySelector('.accordion-chevron');
        if (body.style.display === 'none') {
            body.style.display = 'block';
            chevron.style.transform = 'rotate(180deg)';
        } else {
            body.style.display = 'none';
            chevron.style.transform = 'rotate(0deg)';
        }
    }

    async function createResource() {
        var name = document.getElementById('res_name').value.trim();
        if (!name) {
            HCL.toastError('Resource name is required.');
            return;
        }

        var btn = document.getElementById('addResourceBtn');
        btn.disabled = true;
        btn.textContent = 'Adding...';

        try {
            var result = await HCL.apiRequest('/Admin/Resources/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: name,
                    displayName: document.getElementById('res_displayName').value.trim() || null,
                    description: document.getElementById('res_description').value.trim() || null,
                    enabled: document.getElementById('res_enabled').checked
                })
            });

            if (result.success) {
                HCL.toastSuccess('API resource added successfully.');
                HCL.closeModal('addResourceModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Failed to add resource.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred while adding the resource.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add Resource';
        }
    }

    async function deleteResource(resourceId, resourceName) {
        var ok = await HCL.confirm('Delete API Resource', 'Are you sure you want to permanently delete resource "' + resourceName + '"? All associated scopes will also be removed. This action cannot be undone.');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Resources/Delete/' + resourceId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('Resource deleted successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Failed to delete resource.';
            HCL.toastError(msg);
        }
    }

    function openAddScopeModal(resourceId, resourceName) {
        document.getElementById('scope_resourceId').value = resourceId;
        document.getElementById('scope_name').value = '';
        document.getElementById('scope_displayName').value = '';
        document.getElementById('scope_description').value = '';
        document.getElementById('scope_required').checked = false;
        document.getElementById('scope_emphasize').checked = false;
        document.getElementById('addScopeResourceLabel').textContent = 'Resource: ' + resourceName;
        HCL.openModal('addScopeModal');
    }

    async function createScope() {
        var name = document.getElementById('scope_name').value.trim();
        if (!name) {
            HCL.toastError('Scope name is required.');
            return;
        }

        var btn = document.getElementById('addScopeBtn');
        btn.disabled = true;
        btn.textContent = 'Adding...';

        try {
            var result = await HCL.apiRequest('/Admin/Resources/AddScope', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    apiResourceId: document.getElementById('scope_resourceId').value,
                    name: name,
                    displayName: document.getElementById('scope_displayName').value.trim() || null,
                    description: document.getElementById('scope_description').value.trim() || null,
                    required: document.getElementById('scope_required').checked,
                    emphasize: document.getElementById('scope_emphasize').checked
                })
            });

            if (result.success) {
                HCL.toastSuccess('Scope added successfully.');
                HCL.closeModal('addScopeModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Failed to add scope.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred while adding the scope.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add Scope';
        }
    }

    function openEditScopeModal(scopeId, resourceId, name, displayName, description, required, emphasize) {
        document.getElementById('edit_scope_id').value = scopeId;
        document.getElementById('edit_scope_resourceId').value = resourceId;
        document.getElementById('edit_scope_name').value = name;
        document.getElementById('edit_scope_displayName').value = displayName;
        document.getElementById('edit_scope_description').value = description;
        document.getElementById('edit_scope_required').checked = required;
        document.getElementById('edit_scope_emphasize').checked = emphasize;
        HCL.openModal('editScopeModal');
    }

    async function updateScope() {
        var name = document.getElementById('edit_scope_name').value.trim();
        if (!name) {
            HCL.toastError('Scope name is required.');
            return;
        }

        var btn = document.getElementById('editScopeBtn');
        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
            var result = await HCL.apiRequest('/Admin/Resources/UpdateScope', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: document.getElementById('edit_scope_id').value,
                    apiResourceId: document.getElementById('edit_scope_resourceId').value,
                    name: name,
                    displayName: document.getElementById('edit_scope_displayName').value.trim() || null,
                    description: document.getElementById('edit_scope_description').value.trim() || null,
                    required: document.getElementById('edit_scope_required').checked,
                    emphasize: document.getElementById('edit_scope_emphasize').checked
                })
            });

            if (result.success) {
                HCL.toastSuccess('Scope updated successfully.');
                HCL.closeModal('editScopeModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Failed to update scope.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred while updating the scope.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save Changes';
        }
    }

    async function deleteScope(scopeId, scopeName) {
        var ok = await HCL.confirm('Delete Scope', 'Are you sure you want to delete scope "' + scopeName + '"? This action cannot be undone.');
        if (!ok) return;
        var result = await HCL.apiRequest('/Admin/Resources/DeleteScope/' + scopeId, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('Scope deleted successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Failed to delete scope.';
            HCL.toastError(msg);
        }
    }
</script>
}
