@model List<HCL.CS.SF.Admin.UI.Models.Api.ExternalAuthProviderConfigModel>

@{
    var providers = Model ?? new List<HCL.CS.SF.Admin.UI.Models.Api.ExternalAuthProviderConfigModel>();
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">External Authentication Providers</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            @providers.Count configured provider(s)
        </p>
    </div>
    <div class="hcl-page-actions">
        <button class="hcl-btn hcl-btn-primary" onclick="openAddModal()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Provider
        </button>
    </div>
</div>

<!-- Info Alert -->
<div class="hcl-alert hcl-alert-info" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <span>Configure SAML, OAuth, and OIDC external authentication providers.</span>
</div>

<!-- Provider Cards -->
@if (!providers.Any())
{
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            <p style="color: var(--hcl-text-tertiary);">No external authentication providers configured. Add one to get started.</p>
            <button class="hcl-btn hcl-btn-primary hcl-btn-sm" style="margin-top: 1rem;" onclick="openAddModal()">Add Provider</button>
        </div>
    </div>
}
else
{
    <div class="hcl-grid hcl-grid-3" id="providersGrid">
        @foreach (var provider in providers)
        {
            var configCount = provider.Config?.Count ?? 0;
            var configSummary = configCount > 0
                ? string.Join(", ", provider.Config.Keys.Take(3)) + (configCount > 3 ? $" (+{configCount - 3} more)" : "")
                : "No configuration keys";

            <div class="hcl-card hcl-glass hcl-hover-lift" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem;" data-provider-id="@provider.Id">
                <div style="display: flex; align-items: flex-start; justify-content: space-between;">
                    <div>
                        <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--hcl-text-primary); margin: 0;">
                            @provider.Provider
                        </h3>
                        <p style="font-size: 0.8rem; color: var(--hcl-text-tertiary); margin-top: 0.375rem; line-height: 1.4;">
                            @configSummary
                        </p>
                    </div>
                    <div style="width: 40px; height: 40px; border-radius: 0.5rem; background: linear-gradient(135deg, rgba(59,130,246,0.2), rgba(168,85,247,0.2)); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="color: #3b82f6;"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    @if (provider.IsEnabled)
                    {
                        <span class="hcl-badge hcl-badge-success">Enabled</span>
                    }
                    else
                    {
                        <span class="hcl-badge hcl-badge-danger">Disabled</span>
                    }
                </div>

                <div style="display: flex; gap: 0.5rem; margin-top: auto; padding-top: 0.5rem; border-top: 1px solid var(--hcl-border); flex-wrap: wrap;">
                    <button class="hcl-btn hcl-btn-sm" style="flex: 1; justify-content: center; background: var(--hcl-bg-tertiary); color: var(--hcl-text-secondary); border: 1px solid var(--hcl-border);"
                            onclick='openEditModal(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(provider)))'>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit
                    </button>
                    <button class="hcl-btn hcl-btn-sm" style="justify-content: center; background: rgba(234,179,8,0.15); color: #eab308; border: 1px solid rgba(234,179,8,0.3);"
                            onclick="toggleProvider('@provider.Id', '@provider.Provider', @(provider.IsEnabled ? "true" : "false"))">
                        @if (provider.IsEnabled)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                            <span>Disable</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                            <span>Enable</span>
                        }
                    </button>
                    <button class="hcl-btn hcl-btn-danger hcl-btn-sm" onclick="deleteProvider('@provider.Id', '@provider.Provider')">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        Delete
                    </button>
                </div>
            </div>
        }
    </div>
}

<!-- Add/Edit Provider Modal -->
<div class="hcl-modal-backdrop" id="providerModal">
    <div class="hcl-modal" style="max-width: 600px;">
        <div class="hcl-modal-header">
            <h3 class="hcl-modal-title" id="providerModalTitle">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Add Provider
            </h3>
            <button class="hcl-btn-icon" onclick="HCL.closeModal('providerModal')">&times;</button>
        </div>
        <div class="hcl-modal-body">
            <form id="providerForm" onsubmit="return false;">
                <input type="hidden" id="prov_id" />
                <div class="hcl-form-group">
                    <label class="hcl-label">Provider Type <span style="color: #ef4444;">*</span></label>
                    <select class="hcl-select" id="prov_provider">
                        <option value="">-- Select Type --</option>
                        <option value="SAML">SAML</option>
                        <option value="OAuth2">OAuth 2.0</option>
                        <option value="OIDC">OpenID Connect (OIDC)</option>
                        <option value="Custom">Custom</option>
                    </select>
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Enabled</label>
                    <label class="hcl-toggle-switch">
                        <input type="checkbox" id="prov_enabled" checked />
                        <span></span>
                    </label>
                </div>
                <div class="hcl-form-group">
                    <label class="hcl-label">Configuration (Key / Value)</label>
                    <div id="configFieldsContainer"></div>
                    <button type="button" class="hcl-btn hcl-btn-sm hcl-btn-ghost" onclick="addConfigField('', '')" style="margin-top: 0.5rem;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Field
                    </button>
                </div>
            </form>
        </div>
        <div class="hcl-modal-footer">
            <button class="hcl-btn hcl-btn-ghost" onclick="HCL.closeModal('providerModal')">Cancel</button>
            <button class="hcl-btn hcl-btn-primary" id="saveProviderBtn" onclick="saveProvider()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save Provider
            </button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    @@media (max-width: 768px) {
        .hcl-grid-3 { grid-template-columns: 1fr !important; }
    }
</style>
<script>
    function addConfigField(key, value) {
        var container = document.getElementById('configFieldsContainer');
        var row = document.createElement('div');
        row.style.cssText = 'display: flex; gap: 0.5rem; margin-bottom: 0.5rem; align-items: center;';
        row.innerHTML =
            '<input type="text" class="hcl-input config-key" placeholder="Key (e.g. ClientId)" value="' + (key || '') + '" style="flex: 1;" />' +
            '<input type="text" class="hcl-input config-val" placeholder="Value" value="' + (value || '') + '" style="flex: 1;" />' +
            '<button type="button" class="hcl-btn hcl-btn-sm hcl-btn-danger hcl-btn-icon" onclick="this.parentElement.remove()" style="flex-shrink: 0;">&times;</button>';
        container.appendChild(row);
    }

    function openAddModal() {
        document.getElementById('prov_id').value = '';
        document.getElementById('prov_provider').value = '';
        document.getElementById('prov_enabled').checked = true;
        document.getElementById('configFieldsContainer').innerHTML = '';
        document.getElementById('providerModalTitle').innerHTML =
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Add Provider';

        // Add common default fields based on typical OIDC config
        addConfigField('Authority', '');
        addConfigField('ClientId', '');
        addConfigField('ClientSecret', '');
        HCL.openModal('providerModal');
    }

    function openEditModal(provider) {
        document.getElementById('prov_id').value = provider.id || '';
        document.getElementById('prov_provider').value = provider.provider || '';
        document.getElementById('prov_enabled').checked = provider.isEnabled !== false;
        document.getElementById('configFieldsContainer').innerHTML = '';
        document.getElementById('providerModalTitle').innerHTML =
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="display: inline; vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit Provider';

        var config = provider.config || {};
        var keys = Object.keys(config);
        if (keys.length === 0) {
            addConfigField('', '');
        } else {
            keys.forEach(function(k) { addConfigField(k, config[k]); });
        }
        HCL.openModal('providerModal');
    }

    async function saveProvider() {
        var providerType = document.getElementById('prov_provider').value;
        if (!providerType) {
            HCL.toastError('Provider type is required.');
            return;
        }

        var config = {};
        var keys = document.querySelectorAll('.config-key');
        var vals = document.querySelectorAll('.config-val');
        for (var i = 0; i < keys.length; i++) {
            var k = keys[i].value.trim();
            if (k) config[k] = vals[i].value.trim();
        }

        var btn = document.getElementById('saveProviderBtn');
        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
            var result = await HCL.apiRequest('/Admin/ExternalAuth/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: document.getElementById('prov_id').value || null,
                    provider: providerType,
                    isEnabled: document.getElementById('prov_enabled').checked,
                    config: config
                })
            });

            if (result.success) {
                HCL.toastSuccess('Provider saved successfully.');
                HCL.closeModal('providerModal');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                var msg = result.errors && result.errors.length > 0
                    ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                    : 'Failed to save provider.';
                HCL.toastError(msg);
            }
        } catch (err) {
            HCL.toastError('An error occurred while saving the provider.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save Provider';
        }
    }

    async function toggleProvider(id, name, currentlyEnabled) {
        var action = currentlyEnabled ? 'disable' : 'enable';
        var ok = await HCL.confirm(
            (currentlyEnabled ? 'Disable' : 'Enable') + ' Provider',
            'Are you sure you want to ' + action + ' the provider "' + name + '"?'
        );
        if (!ok) return;

        try {
            var result = await HCL.apiRequest('/Admin/ExternalAuth/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: id,
                    provider: name,
                    isEnabled: !currentlyEnabled
                })
            });

            if (result.success) {
                HCL.toastSuccess('Provider ' + action + 'd successfully.');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                HCL.toastError('Failed to ' + action + ' provider.');
            }
        } catch (err) {
            HCL.toastError('An error occurred.');
        }
    }

    async function deleteProvider(id, name) {
        var ok = await HCL.confirm('Delete Provider', 'Are you sure you want to delete the provider "' + name + '"? This action cannot be undone.');
        if (!ok) return;

        var result = await HCL.apiRequest('/Admin/ExternalAuth/Delete/' + id, { method: 'POST' });
        if (result.success) {
            HCL.toastSuccess('Provider deleted successfully.');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            var msg = result.errors && result.errors.length > 0
                ? result.errors.map(function(e) { return e.description || e.code; }).join(', ')
                : 'Failed to delete provider.';
            HCL.toastError(msg);
        }
    }
</script>
}
