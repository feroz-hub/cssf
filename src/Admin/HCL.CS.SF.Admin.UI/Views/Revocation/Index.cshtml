@{
    var clients = (ViewBag.Clients as List<HCL.CS.SF.Admin.UI.Models.Api.ClientsModel>) ?? new List<HCL.CS.SF.Admin.UI.Models.Api.ClientsModel>();
}

<!-- Page Header -->
<div class="hcl-page-header">
    <div>
        <h1 class="hcl-page-title">
            <span class="hcl-gradient-text">Token Revocation</span>
        </h1>
        <p style="color: var(--hcl-text-secondary); margin-top: 0.25rem; font-size: 0.875rem;">
            Search and revoke active OAuth tokens
        </p>
    </div>
</div>

<!-- Warning Alert -->
<div class="hcl-alert hcl-alert-warning" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="flex-shrink: 0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <span>Revoking tokens immediately invalidates them. This action cannot be undone.</span>
</div>

<!-- Search Section with Tabs -->
<div class="hcl-card hcl-glass" style="padding: 1.25rem; margin-bottom: 1.5rem;">
    <div class="hcl-tabs" style="margin-bottom: 1rem;">
        <button class="hcl-tab active" id="tabByClient" onclick="switchTab('client')">By Client</button>
        <button class="hcl-tab" id="tabByUser" onclick="switchTab('user')">By User</button>
    </div>

    <!-- By Client Tab -->
    <div id="panelByClient" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 250px;">
            <label class="hcl-label">Client</label>
            <select class="hcl-select" id="searchClientId">
                <option value="">-- Select a Client --</option>
                @foreach (var c in clients)
                {
                    <option value="@c.ClientId">@c.ClientId — @(c.ClientName ?? c.ClientId)</option>
                }
            </select>
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0;">
            <button class="hcl-btn hcl-btn-primary" onclick="searchByClient()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Search
            </button>
        </div>
    </div>

    <!-- By User Tab -->
    <div id="panelByUser" style="display: none; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div class="hcl-form-group" style="margin-bottom: 0; flex: 1; min-width: 250px;">
            <label class="hcl-label">User ID</label>
            <input type="text" class="hcl-input" id="searchUserId" placeholder="Enter user ID or subject ID..." />
        </div>
        <div class="hcl-form-group" style="margin-bottom: 0;">
            <button class="hcl-btn hcl-btn-primary" onclick="searchByUser()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Search
            </button>
        </div>
    </div>
</div>

<!-- Loading State -->
<div id="loadingState" style="display: none;">
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <div style="width: 40px; height: 40px; border: 3px solid var(--hcl-border); border-top-color: var(--hcl-accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem;"></div>
            <p style="color: var(--hcl-text-tertiary);">Searching tokens...</p>
        </div>
    </div>
</div>

<!-- Empty State -->
<div id="emptyState" style="display: none;">
    <div class="hcl-card hcl-glass">
        <div class="hcl-empty-state" style="padding: 3rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--hcl-text-tertiary); margin-bottom: 1rem;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <p style="color: var(--hcl-text-tertiary);">No active tokens found for the given criteria.</p>
        </div>
    </div>
</div>

<!-- Results Table -->
<div id="resultsContainer" style="display: none;">
    <div style="display: flex; justify-content: flex-end; margin-bottom: 0.75rem;">
        <button class="hcl-btn hcl-btn-danger hcl-btn-sm" id="bulkRevokeBtn" onclick="bulkRevoke()" style="display: none;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            Revoke Selected
        </button>
    </div>
    <div class="hcl-card hcl-glass">
        <div class="hcl-table-wrapper">
            <table class="hcl-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" class="hcl-checkbox" id="selectAllTokens" onchange="toggleSelectAll(this)" /></th>
                        <th>Client ID</th>
                        <th>User ID</th>
                        <th>Token Type</th>
                        <th>Created</th>
                        <th>Expires</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="tokensTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@media (max-width: 768px) {
        #panelByClient, #panelByUser { flex-direction: column; }
    }
</style>
<script>
    var tokensData = [];

    function switchTab(tab) {
        document.getElementById('tabByClient').classList.toggle('active', tab === 'client');
        document.getElementById('tabByUser').classList.toggle('active', tab === 'user');
        document.getElementById('panelByClient').style.display = tab === 'client' ? 'flex' : 'none';
        document.getElementById('panelByUser').style.display = tab === 'user' ? 'flex' : 'none';
    }

    function getTokenTypeBadge(type) {
        if (!type) return '<span class="hcl-badge hcl-badge-primary">unknown</span>';
        if (type.toLowerCase().indexOf('refresh') !== -1) {
            return '<span class="hcl-badge hcl-badge-purple">refresh_token</span>';
        }
        return '<span class="hcl-badge hcl-badge-primary">access_token</span>';
    }

    function showLoading() {
        document.getElementById('loadingState').style.display = '';
        document.getElementById('emptyState').style.display = 'none';
        document.getElementById('resultsContainer').style.display = 'none';
    }

    function showResults(tokens) {
        document.getElementById('loadingState').style.display = 'none';
        tokensData = tokens || [];

        if (tokensData.length === 0) {
            document.getElementById('emptyState').style.display = '';
            document.getElementById('resultsContainer').style.display = 'none';
            return;
        }

        renderTokens();
        document.getElementById('resultsContainer').style.display = '';
    }

    function renderTokens() {
        var tbody = document.getElementById('tokensTableBody');
        var html = '';
        tokensData.forEach(function(token, idx) {
            html += '<tr id="tokenRow_' + idx + '">' +
                '<td><input type="checkbox" class="hcl-checkbox token-check" data-idx="' + idx + '" onchange="updateBulkBtn()" /></td>' +
                '<td data-label="Client ID" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (token.clientId || 'N/A') + '</td>' +
                '<td data-label="User ID" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (token.userId || token.subjectId || 'N/A') + '</td>' +
                '<td data-label="Token Type">' + getTokenTypeBadge(token.tokenType) + '</td>' +
                '<td data-label="Created" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (token.creationTime ? HCL.formatDateTime(token.creationTime) : 'N/A') + '</td>' +
                '<td data-label="Expires" style="color: var(--hcl-text-secondary); font-size: 0.875rem;">' + (token.expiresAt ? HCL.formatDateTime(token.expiresAt) : 'N/A') + '</td>' +
                '<td data-label="Actions" style="text-align: right;">' +
                    '<button class="hcl-btn hcl-btn-danger hcl-btn-sm" onclick="revokeToken(' + idx + ')">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>' +
                        ' Revoke' +
                    '</button>' +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
        document.getElementById('selectAllTokens').checked = false;
        updateBulkBtn();
    }

    async function searchByClient() {
        var clientId = document.getElementById('searchClientId').value;
        if (!clientId) {
            HCL.toastError('Please select a client.');
            return;
        }
        showLoading();
        try {
            var result = await HCL.apiRequest('/Admin/Revocation/SearchByClient', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify([clientId])
            });
            showResults(result);
        } catch (err) {
            document.getElementById('loadingState').style.display = 'none';
            HCL.toastError('Failed to search tokens.');
        }
    }

    async function searchByUser() {
        var userId = document.getElementById('searchUserId').value.trim();
        if (!userId) {
            HCL.toastError('Please enter a user ID.');
            return;
        }
        showLoading();
        try {
            var result = await HCL.apiRequest('/Admin/Revocation/SearchByUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify([userId])
            });
            showResults(result);
        } catch (err) {
            document.getElementById('loadingState').style.display = 'none';
            HCL.toastError('Failed to search tokens.');
        }
    }

    async function revokeToken(idx) {
        var token = tokensData[idx];
        if (!token) return;

        var ok = await HCL.confirm('Revoke Token', 'Are you sure you want to revoke this ' + (token.tokenType || 'token') + '? This action cannot be undone.');
        if (!ok) return;

        try {
            var result = await HCL.apiRequest('/Admin/Revocation/Revoke', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    token: token.tokenValue || token.key || token.id,
                    tokenTypeHint: token.tokenType || 'access_token'
                })
            });

            if (result.success) {
                HCL.toastSuccess('Token revoked successfully.');
                tokensData.splice(idx, 1);
                if (tokensData.length === 0) {
                    showResults([]);
                } else {
                    renderTokens();
                }
            } else {
                HCL.toastError('Failed to revoke token.');
            }
        } catch (err) {
            HCL.toastError('An error occurred while revoking the token.');
        }
    }

    function toggleSelectAll(el) {
        var checks = document.querySelectorAll('.token-check');
        checks.forEach(function(c) { c.checked = el.checked; });
        updateBulkBtn();
    }

    function updateBulkBtn() {
        var checked = document.querySelectorAll('.token-check:checked');
        document.getElementById('bulkRevokeBtn').style.display = checked.length > 0 ? '' : 'none';
    }

    async function bulkRevoke() {
        var checked = document.querySelectorAll('.token-check:checked');
        if (checked.length === 0) return;

        var ok = await HCL.confirm('Bulk Revoke', 'Are you sure you want to revoke ' + checked.length + ' selected token(s)? This action cannot be undone.');
        if (!ok) return;

        var indices = [];
        checked.forEach(function(c) { indices.push(parseInt(c.getAttribute('data-idx'))); });
        indices.sort(function(a, b) { return b - a; }); // reverse so splice works correctly

        var errors = 0;
        for (var i = 0; i < indices.length; i++) {
            var token = tokensData[indices[i]];
            if (!token) continue;
            try {
                var result = await HCL.apiRequest('/Admin/Revocation/Revoke', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        token: token.tokenValue || token.key || token.id,
                        tokenTypeHint: token.tokenType || 'access_token'
                    })
                });
                if (result.success) {
                    tokensData.splice(indices[i], 1);
                } else {
                    errors++;
                }
            } catch (err) {
                errors++;
            }
        }

        if (errors > 0) {
            HCL.toastError(errors + ' token(s) failed to revoke.');
        } else {
            HCL.toastSuccess('All selected tokens revoked successfully.');
        }

        if (tokensData.length === 0) {
            showResults([]);
        } else {
            renderTokens();
        }
    }
</script>
}
