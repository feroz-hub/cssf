{
  "info": {
    "_postman_id": "0e95fb20-b26e-4f01-9414-57f3f2f2b9aa",
    "name": "HCL.CS.SF Local OAuth OIDC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:5001"
    },
    {
      "key": "clientId",
      "value": "rqAAZmznolU3lSesJE0LMJfbKcPK6dzGZJ0Tyo0Jm2c="
    },
    {
      "key": "clientSecret",
      "value": "5R3WAyAKxggITT3STfrk%2BaBxjSa5nZcT3CiWUqYSAWU="
    },
    {
      "key": "redirectUri",
      "value": "https://localhost:5000/signin-oidc"
    },
    {
      "key": "scope",
      "value": "openid profile email offline_access phone HCL.CS.SF.apiresource HCL.CS.SF.client HCL.CS.SF.user HCL.CS.SF.role HCL.CS.SF.identityresource HCL.CS.SF.adminuser HCL.CS.SF.securitytoken"
    },
    {
      "key": "codeVerifier",
      "value": "dBjftJeZ4CVP-mB92K27uhbUJU1p1r_wW1gFWFOEjXk"
    },
    {
      "key": "codeChallenge",
      "value": "E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM"
    },
    {
      "key": "authCode",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "OIDC Discovery",
      "item": [
        {
          "name": "Discovery Document",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/.well-known/openid-configuration",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ".well-known",
                "openid-configuration"
              ]
            }
          },
          "response": []
        },
        {
          "name": "JWKS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/.well-known/openid-configuration/jwks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ".well-known",
                "openid-configuration",
                "jwks"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authorization Code + PKCE",
      "item": [
        {
          "name": "Authorize (open in browser)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/security/authorize?client_id={{clientId}}&redirect_uri={{redirectUri}}&response_type=code&scope={{scope}}&code_challenge={{codeChallenge}}&code_challenge_method=S256&state=postman-state-123&nonce=postman-nonce-123",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "authorize"
              ],
              "query": [
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirectUri}}"
                },
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                },
                {
                  "key": "code_challenge",
                  "value": "{{codeChallenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                },
                {
                  "key": "state",
                  "value": "postman-state-123"
                },
                {
                  "key": "nonce",
                  "value": "postman-nonce-123"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Token - Authorization Code",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{clientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{clientSecret}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text"
                },
                {
                  "key": "code",
                  "value": "{{authCode}}",
                  "type": "text"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirectUri}}",
                  "type": "text"
                },
                {
                  "key": "code_verifier",
                  "value": "{{codeVerifier}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/security/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "if (jsonData.access_token) pm.environment.set('accessToken', jsonData.access_token);",
                  "if (jsonData.refresh_token) pm.environment.set('refreshToken', jsonData.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Token - Refresh",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{clientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{clientSecret}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "refresh_token",
                  "type": "text"
                },
                {
                  "key": "refresh_token",
                  "value": "{{refreshToken}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/security/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "if (jsonData.access_token) pm.environment.set('accessToken', jsonData.access_token);",
                  "if (jsonData.refresh_token) pm.environment.set('refreshToken', jsonData.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Introspection and Revocation",
      "item": [
        {
          "name": "Introspect Access Token",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{clientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{clientSecret}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "text"
                },
                {
                  "key": "token_type_hint",
                  "value": "access_token",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/security/introspect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "introspect"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Revoke Refresh Token",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{clientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{clientSecret}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "token",
                  "value": "{{refreshToken}}",
                  "type": "text"
                },
                {
                  "key": "token_type_hint",
                  "value": "refresh_token",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/security/revocation",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "revocation"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "UserInfo",
      "item": [
        {
          "name": "Get UserInfo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/security/userinfo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "security",
                "userinfo"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
