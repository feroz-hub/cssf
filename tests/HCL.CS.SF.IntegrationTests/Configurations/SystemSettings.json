{
  "SystemSettings": {
    "DBConfig": {
      "Database": "SqlServer",
      "DBConnectionString": "Server=localhost\\SQLEXPRESS;Database=HCL.CS.SFIntegrationTest;Trusted_Connection=True;MultipleActiveResultSets=true"
    },
    "LoginConfig": {
      "IsPersistent": false,
      "LockoutOnFailure": true,
      "RememberClient": false
    },
    "UserConfig": {
      "MinUserNameLength": 8,
      "MaxUserNameLength": 255,
      "MinFirstAndLastNameLength": 2,
      "MaxFirstAndLastNameLength": 255,
      "MinPhoneNumberLength": 4,
      "MaxPhoneNumberLength": 17,
      "MinSecurityQuestions": 0,
      "MinSecurityAnswersLength": 3,
      "MinDobyear": 18,
      "MaxDobyear": 100,
      "AccessFailedCount": 3,
      "RequiredRecoveryCodes": 2,
      "RequireUniqueEmail": true,
      "RequireConfirmedEmail": true,
      "RequireConfirmedPhoneNumber": true,
      "LockOutAllowedForNewUsers": true,
      "DefaultLockoutTimeSpanMin": 10,
      "MaxFailedAccessAttempts": 3,
      "EmailTokenExpiry": 5,
      "OTPTokenExpiry": 5,
      "PasswordResetTokenExpiry": 5,
      "UserTokenExpiry": 5,
      "LockAccountPeriod": 30,
      "MinNoOfQuestions": 1
    },
    "PasswordConfig": {
      "MinPasswordLength": 8,
      "MaxPasswordLength": 40,
      "RequiredUniqueChars": 1,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireSpecialChar": true,
      "PasswordPattern": "",
      "MaxLimitPasswordReuse": 3,
      "MaxPasswordExpiry": 30,
      "PasswordNotificationBeforeExpiry": 3
    },
    "EmailConfig": {
      "SmtpServer": "mailrelay.HCL.CS.SF.com",
      "Port": "25",
      "UseDefaultCredentials": false,
      "SecureSocketOptions": true,
      "UserName": "${HCL.CS.SF_SMTP_USERNAME}",
      "Password": "${HCL.CS.SF_SMTP_PASSWORD}",
      "EmailNotificationType": "Link"
    },
    "SMSConfig": {
      "SMSAccountIdentification": "${HCL.CS.SF_SMS_ACCOUNT_ID}",
      "SMSAccountPassword": "${HCL.CS.SF_SMS_ACCOUNT_PASSWORD}",
      "SMSAccountFrom": "${HCL.CS.SF_SMS_ACCOUNT_FROM}",
      "SMSStatusCallbackURL": "https://www.google.co.in/"
    },
    "LDAPConfig": {
      "LdapHostName": "localhost",
      "LdapDomainName": "dc=example,dc=com",
      //"LDAPPort": "10389",
      //"IsSecureConnection": "false",
      "LDAPPort": "10636",
      "IsSecureConnection": "true",
      "IsTwoFactorAuthenticationRequired": "false",
      "TwoFactorType": "Email"
    },
    "CryptoConfig": {
      "RandomStringLength": 32
    },
    "LogConfig": {
      "WriteLogTo": "File",
      "LogFileConfig": {
        "FilePath": "",
        "RollingIntervalType": "Month",
        "RestrictedToMinimumLevel": "Debug",
        "MinimumConfiguration": "Debug",
        "SetLogFileSize": "true",
        "FileSizeInBytes": "5242880"
      },
      "LogDbConfig": {
        "Database": "PostgreSQL",
        "ConnectionString": "",
        "RestrictedToMinimumLevel": "Debug",
        "MinimumConfiguration": "Debug"
      }
    }
  }
}
