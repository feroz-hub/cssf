<div>
    <h4>User Roles</h4>
    <hr/>
    @if (TempData["msg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["msg"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="form-group">
        <table id="UserRole" cellpadding="0" cellspacing="0"></table>
        <div id="UserRolePager"></div>

    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(function () {
            var $resources = $('#UserRole');
            $resources.jqGrid({
                url: '@Url.Action("GetAllUsers", "ManageApi")',
                datatype: 'json',
                mtype: 'POST',
                colNames: ['UserId', 'UserName', 'AccountStatus', 'ManageRole', 'Claims'],
                colModel: [
                    {name: 'UserId', sortable: false, editable: false, width: 350},
                    {name: 'UserName', sortable: false, editable: true, editrules: {required: true}, width: 150},
                    {
                        name: 'AccountStatus', width: 150,
                        formatter: function (cellvalue, options, rowObject) {
                            return '<a class="AccountStatus" style="color: Blue"  href="/ManageApi/UpdateAccountStatus/?userId=' + rowObject.id + '&dataValue=' + cellvalue + '">' + cellvalue + '</a>';
                        }
                    },
                    {
                        name: 'ManageRole', width: 150,
                        formatter: function (cellvalue, options, rowObject) {
                            return '<a class="ManageRole" style="color: Blue"  href="/ManageApi/ManageRoles/?userId=' + rowObject.id + '&dataValue=' + cellvalue + '"> ManageRole</a>';
                        }
                    },
                    {
                        name: 'Claims', width: 150,
                        formatter: function (cellvalue, options, rowObject) {
                            return '<a class="Claims" style="color: Blue"  href="/ManageApi/ManageClaims/?userId=' + rowObject.id + '&dataValue=' + cellvalue + '">Claims</a>';
                        }
                    }],

                caption: 'UserRole',
                footerrow: true,
                userDataOnFooter: true,
                jsonReader: {repeatitems: false, id: 'Id'},
                pager: $('#UserRolePager'),
                rowNum: 10,
                viewrecords: true,
                height: '100%',
            });
        });
    </script>
}
