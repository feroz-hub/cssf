<div>
    <h5>Identity resource claims for resource - <strong>"@ViewData["resourcename"]"</strong></h5>
    <hr/>
    <div class="form-group">
        <div id="messageDiv"></div>
        <table id="IdentityResourceClaims" cellpadding="0" cellspacing="0"></table>
        <div id="IdentityResourceClaimsPager"></div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(function () {
            var $resources = $('#IdentityResourceClaims');
            $resources.jqGrid({
                url: '@Url.Action("GetIdentityResourceClaimsById", "ManageApi", new { identityResourceId = ViewData["resourceid"] })',
                editurl: '@Url.Action("ManageIdentityResourceClaims", "ManageApi", new { identityResourceId = ViewData["resourceid"] })',
                datatype: 'json',
                mtype: 'POST',
                colNames: ['Id', 'Type', 'AliasType'],
                colModel: [
                    {name: 'Id', sortable: false, editable: false, width: 300},
                    {name: 'Type', sortable: false, editable: true, width: 200},
                    {name: 'AliasType', sortable: false, editable: true, width: 200}],
                caption: 'Identity Resource Claims',
                footerrow: true,
                userDataOnFooter: true,
                jsonReader: {repeatitems: false, id: 'Id'},
                pager: $('#IdentityResourceClaimsPager'),
                rowNum: 10,
                viewrecords: true,
                height: '100%',
            })
                .jqGrid('navGrid', '#IdentityResourceClaimsPager', {add: false, edit: false, del: true, search: false})
                .jqGrid('inlineNav', '#IdentityResourceClaimsPager', {
                    edit: false,
                    addParams: {
                        useDefValues: true,
                        addRowParams: {
                            keys: true,
                            extraparam: {},
                            successfunc: function (val) {
                                if (val.responseText != "") {
                                    if (val.responseText == '"Success"') {
                                        $("#messageDiv").append("<div id='divSuccess' class='alert alert-success alert-dismissible fade show' role='alert'><p id='SuccessMessgage'>Identity resdource claim successfully added.</p> <button type='button' class='close' data-dismiss='alert' aria-label='Close'><span aria-hidden='true'>&times;</span></button></div>");
                                        $(this).jqGrid('setGridParam', {datatype: 'json'}).trigger('reloadGrid');
                                    } else {
                                        $("#messageDiv").append("<div id='divSuccess' class='alert alert-danger alert-dismissible fade show' role='alert'><p id='SuccessMessgage'>" + val.responseText + "</p> <button type='button' class='close' data-dismiss='alert' aria-label='Close'><span aria-hidden='true'>&times;</span></button></div>");
                                    }
                                }
                            }
                        }
                    },
                    editParams: {
                        keys: false,
                        oneditfunc: null,
                        successfunc: function (val) {
                            if (val.responseText != "") {
                                $(this).jqGrid('setGridParam', {datatype: 'json'}).trigger('reloadGrid');
                            }
                        }
                    }
                })
            //.bind('jqGridInlineSuccessSaveRow', demo.jqGrid.onJqGridInlineSuccessSaveRow)
            //.bind('jqGridInlineAfterSaveRow', demo.jqGrid.onJqGridInlineAfterSaveRow);
        });
    </script>
}
