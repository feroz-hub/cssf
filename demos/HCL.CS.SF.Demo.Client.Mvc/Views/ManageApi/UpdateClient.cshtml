@model HCL.CS.SF.DemoClientMvc.Models.ManageClientViewModel
<h2>@ViewBag.Title</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <h4>Update Client</h4>
            <hr/>
            <input type="hidden" asp-for="ClientId"/>
            <div class="form-group">
                <label asp-for="ClientName"></label>
                <input asp-for="ClientName" class="form-control"/>
                <span asp-validation-for="ClientName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ClientUri"></label>
                <input asp-for="ClientUri" class="form-control"/>
                <span asp-validation-for="ClientUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LogoUri"></label>
                <input asp-for="LogoUri" class="form-control"/>
                <span asp-validation-for="LogoUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TermsOfServiceUri"></label>
                <input asp-for="TermsOfServiceUri" class="form-control"/>
                <span asp-validation-for="TermsOfServiceUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PolicyUri"></label>
                <input asp-for="PolicyUri" class="form-control"/>
                <span asp-validation-for="PolicyUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RefreshTokenExpiration"></label>
                <input asp-for="RefreshTokenExpiration" class="form-control"/>
                <span asp-validation-for="RefreshTokenExpiration" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AccessTokenExpiration"></label>
                <input asp-for="AccessTokenExpiration" class="form-control"/>
                <span asp-validation-for="AccessTokenExpiration" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdentityTokenExpiration"></label>
                <input asp-for="IdentityTokenExpiration" class="form-control"/>
                <span asp-validation-for="IdentityTokenExpiration" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LogoutTokenExpiration"></label>
                <input asp-for="LogoutTokenExpiration" class="form-control"/>
                <span asp-validation-for="LogoutTokenExpiration" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AuthorizationCodeExpiration"></label>
                <input asp-for="AuthorizationCodeExpiration" class="form-control"/>
                <span asp-validation-for="AuthorizationCodeExpiration" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AllowedSigningAlgorithm"></label>
                <input asp-for="AllowedSigningAlgorithm" class="form-control"/>
                <span asp-validation-for="AllowedSigningAlgorithm" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FrontChannelLogoutUri"></label>
                <input asp-for="FrontChannelLogoutUri" class="form-control"/>
                <span asp-validation-for="FrontChannelLogoutUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BackChannelLogoutUri"></label>
                <input asp-for="BackChannelLogoutUri" class="form-control"/>
                <span asp-validation-for="BackChannelLogoutUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SupportedGrantTypes"></label>
                <input asp-for="SupportedGrantTypes" class="form-control"/>
                <span asp-validation-for="SupportedGrantTypes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SupportedResponseTypes"></label>
                <input asp-for="SupportedResponseTypes" class="form-control"/>
                <span asp-validation-for="SupportedResponseTypes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AllowedScopes"></label>
                <input asp-for="AllowedScopes" class="form-control"/>
                <span asp-validation-for="AllowedScopes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Update" class="btn btn-sm btn-primary text-uppercase rounded-0"/>
            </div>
        </form>
    </div>
</div>
