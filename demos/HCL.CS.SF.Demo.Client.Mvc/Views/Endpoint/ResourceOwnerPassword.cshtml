@model HCL.CS.SF.DemoClientMvc.ViewModels.Endpoint.ResourceOwnerPasswordPageViewModel

<div class="row g-3">
    <div class="col-12 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Resource Owner Password Flow</h2>
                <p class="text-muted small">
                    Uses <code>OAuth:ResourceOwnerClientId</code> and <code>OAuth:ResourceOwnerClientSecret</code> when
                    configured.
                    For standards-compliant production setups, prefer Authorization Code + PKCE.
                </p>
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control"/>
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control"/>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Generate Token</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h5">Result</h3>
                @if (!Model.Result.Succeeded)
                {
                    @if (!string.IsNullOrWhiteSpace(Model.Result.ErrorDescription))
                    {
                        <div class="alert alert-danger">@Model.Result.ErrorDescription</div>
                    }
                    else
                    {
                        <p class="text-muted">No token response yet.</p>
                    }
                }
                else
                {
                    <div class="mb-2"><strong>Token Type:</strong> @Model.Result.TokenType</div>
                    <div class="mb-2"><strong>Expires In:</strong> @Model.Result.ExpiresIn seconds</div>
                    <div class="alert alert-success">Token issued successfully. Raw token rendering is disabled.</div>

                    <h4 class="h6 mt-3">Claims</h4>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Type</th>
                                <th>Value</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var claim in Model.Result.Claims)
                            {
                                <tr>
                                    <td><code>@claim.Type</code></td>
                                    <td class="text-break">@claim.Value</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
