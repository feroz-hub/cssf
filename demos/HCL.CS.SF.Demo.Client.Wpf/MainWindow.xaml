<Window x:Class="HCL.CS.SF.DemoClientWpfApp.MainWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HCL.CS.SF.DemoClientWpfApp"
      xmlns:view="clr-namespace:HCL.CS.SF.DemoClientWpfApp.View" xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel"
        mc:Ignorable="d" Background="WhiteSmoke"
    Height="{Binding SystemParameters.PrimaryScreenHeight}" 
    Width="{Binding SystemParameters.PrimaryScreenWidth}"
      Title="HCL.CS.SF Demo"  WindowStartupLocation="CenterScreen" WindowState="Maximized" 
        SizeToContent="Manual" Icon="Image/HCL.CS.SFLogo.jpg">
    <Grid  HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="White" >
        <!--ROOT GRID-2 ROWS 1 COLUMN-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition  MinWidth="1200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--Header Content-->
        <Border Background="{StaticResource PrimaryDarkBrush}" Grid.Row="0" Grid.Column="0" CornerRadius="8" 
                 BorderBrush="{StaticResource PrimaryLightBrush}"  BorderThickness="2" HorizontalAlignment="Left" Width="1200">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
                    <StackPanel.Background>
                        <ImageBrush/>
                    </StackPanel.Background>
                    <Image Height="60" Width="60" Source="/Image/HCL.CS.SFLogo.jpg" Margin="12,0,10,0" ></Image>
                    <TextBlock   Text="HCL.CS.SF Demo" Foreground="White" Margin="30,30,20,10"   FontSize="25" FontWeight="Bold" />
                </StackPanel>
                <StackPanel  Name="stkDashboarddetails" Visibility="{Binding StkDashboarddetails }" Grid.Column="2" Grid.Row="0" HorizontalAlignment="Right">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="2" FontSize="15"  HorizontalAlignment="Left" FontWeight="Bold" Content="Logout" Cursor="Hand" Command="{Binding Path=GotoLogoutCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock TextDecorations="Underline">  
                                 <ContentPresenter />
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="true">
                                            <Setter Property="Foreground" Value="Red" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Label  Grid.Column="0" Grid.Row="0" Content="User Name:" FontWeight="Bold" Foreground="White"  FontSize="12"   HorizontalAlignment="Left" Name="DashboardUserNameLable" />
                        <Label Grid.Column="1" Grid.Row="0"  Content="{Binding LoginUserName}" FontWeight="Bold" Foreground="White"  FontSize="12"   HorizontalAlignment="Left" Name="DashboardUserName" />
                        <Label Grid.Column="0" Grid.Row="1" Margin="0 10 0 0"  Content="Role(s):" Grid.ColumnSpan="1" FontWeight="Bold" Foreground="White"  FontSize="12"   HorizontalAlignment="Left" Name="DashboardUserRoleLable" />
                        <TextBlock Grid.Column="1" Grid.Row="1" Margin="0 15 0 0" Width="200" TextWrapping="Wrap" Text="{Binding Path=RoleName, Mode = TwoWay, UpdateSourceTrigger=PropertyChanged}"  FontWeight="Bold" Foreground="White" FontSize="12"  HorizontalAlignment="Left" Name="DashboardUserRole" />
                    </Grid>
                </StackPanel>
            </Grid>

        </Border>
        <!--Body Content-->
        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.RowSpan="2"  Grid.Column="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"></ColumnDefinition>
                    <ColumnDefinition MinWidth="1100"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="550"></RowDefinition>
                </Grid.RowDefinitions>
                <Border CornerRadius="7" BorderBrush="LightGray" BorderThickness="3">
                <StackPanel Grid.Row="0" Grid.Column="0" Background="{StaticResource ControlContentBrush}">
                    <Button ToolTip="Home Page" Cursor="Hand" Width="70" Height="100" Background="Transparent"  BorderBrush="Transparent" Name="Home" Command="{Binding Path=HomeCommand}">
                        <StackPanel Orientation='Vertical' HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Stretch="Fill" Source="Image/home.jpeg"/>
                            <TextBlock Text="Login" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button ToolTip="User Managment" Cursor="Hand" Width="70" Height="100" Background="Transparent"  BorderBrush="Transparent"  Name="ForgotPassword" Command="{Binding Path=UserManageCommend}" Visibility="{Binding UserManagebuttonVisibility}">
                        <StackPanel Orientation='Vertical' HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Stretch="Fill" Source="Image/UserManager.jpeg"/>
                            <TextBlock Text="User" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button ToolTip="API calls for security features"  Cursor="Hand" Width="70" Height="100" Background="Transparent"  BorderBrush="Transparent"  Name="APICall" Command="{Binding Path=APICallCommend}" Visibility="{Binding APICallVisibility}">
                        <StackPanel Orientation='Vertical' HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Stretch="Fill" Source="Image/API.jpeg"/>
                            <TextBlock Text="API" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button ToolTip="OAuth 2.0/OpenID  Endpoins call for authorization" Cursor="Hand" Width="70" Height="100" Background="Transparent"  BorderBrush="Transparent"  Name="EndPoint" Command="{Binding Path=EndPointCommend}" Visibility="{Binding EndPointVisibility}">
                        <StackPanel Orientation='Vertical' HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Stretch="Fill" Source="Image/EndPointCall.png"/>
                            <TextBlock Text="Endpoint" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </Border>
                <StackPanel Grid.Row="0" Grid.Column="1">
                    <ContentControl Content="{Binding CurrentPageViewModel}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
