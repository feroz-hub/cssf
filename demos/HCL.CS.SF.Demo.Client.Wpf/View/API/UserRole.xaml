<UserControl x:Class="HCL.CS.SF.DemoClientWpfApp.View.UserRole"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:intr="http://schemas.microsoft.com/xaml/behaviors" xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:UserRoleViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="700" HorizontalAlignment="Center">

    <UserControl.Resources>
        <Style x:Key="AccountStatusStyle" TargetType="{x:Type Button}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsReadOnly}" Value="True">
                    <DataTrigger.Setters>
                        <Setter Property="Content" Value="In Active" />
                    </DataTrigger.Setters>
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=IsReadOnly}" Value="False">
                    <DataTrigger.Setters>
                        <Setter Property="Content" Value="Active" />
                    </DataTrigger.Setters>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <intr:Interaction.Triggers>
        <intr:EventTrigger EventName="Loaded">
            <intr:InvokeCommandAction Command="{Binding OnLoadCommand}"/>
        </intr:EventTrigger>
    </intr:Interaction.Triggers>
    <StackPanel>
        <Grid x:Name="LayoutRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="20,2,20,5" Background="Transparent">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Background="WhiteSmoke" Margin="10,10,10,5" >
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                    </Grid.ColumnDefinitions>
                    <Label HorizontalAlignment="Left" HorizontalContentAlignment="Left"   FontSize="15" Foreground="Black" FontWeight="Bold" Content="USER ROLES"/>
                 
                        <DataGrid   AutoGenerateColumns="False"   ItemsSource="{Binding User}"  CanUserAddRows="False"  HeadersVisibility="Column"  HorizontalAlignment="Left"    Name="grdKitsGroupingParent" VerticalAlignment="Center"   Grid.Row="2" RowDetailsVisibilityMode="Visible" SelectedItem="{Binding Path=SelectedItem , Mode=TwoWay}"  Height="300" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn CanUserReorder="True"    CanUserResize="True" CanUserSort="True" IsReadOnly="False" Width="auto" Binding="{Binding Path= Id}" Header="USER ID"  Foreground="Black">
                                </DataGridTextColumn>

                                <DataGridTextColumn CanUserReorder="True" CanUserResize="True" CanUserSort="True" IsReadOnly="False" Width="auto" Binding="{Binding UserName}" Header="USER NAME"  Foreground="Black">
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="MANAGE ROLE"   IsReadOnly="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnAdd"  ToolTip="Add Role" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Tag="{Binding Name}" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.AddUserRoleCommand}" CommandParameter="{Binding ElementName=grdKitsGroupingParent,Path=SelectedItem}"  >
                                                <Image Height="15" Stretch="Fill" Width="15" Source="/Image/Edit.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn  Header="ACCOUNT STATUS" IsReadOnly="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Name="btnUpdate" Cursor="Hand" ToolTip="Update Role"  FontWeight="Bold"   Tag="{Binding Name}" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.LockUnLockCommand}" CommandParameter="{Binding ElementName=grdKitsGroupingParent,Path=SelectedItem}"  >
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock TextDecorations="Underline">  
                                                     <ContentPresenter />
                                                        </TextBlock>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter Property="Foreground" Value="Red" />
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding LockoutEnabled}" Value="False">
                                                                <Setter Property="Content" Value="Active"/>
                                                                <Setter Property="Foreground" Value="Green" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LockoutEnabled}" Value="True">
                                                                <Setter Property="Content" Value="In-Active"/>
                                                                <Setter Property="Foreground" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn  Header="VIEW CLAIMS" IsReadOnly="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnView" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.ViewUserClaimCommand}" CommandParameter="{Binding ElementName=grdKitsGroupingParent,Path=SelectedItem}"  ToolTip="Expand" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Tag="{Binding Name}" >
                                                <Image Height="15" Width="15" Source="/Image/Viewicon.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                </Grid>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
