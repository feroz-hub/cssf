<Window x:Class="HCL.CS.SF.DemoClientWpfApp.View.API.UserRolePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="UserRolePopup" Height="350" Width="350" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid >
        <Grid  Height="auto" Width="auto" Background="#5D6D7E" Margin="10,10,10,5">
            <Grid.ColumnDefinitions></Grid.ColumnDefinitions>
            <Grid.RowDefinitions></Grid.RowDefinitions>
            <Grid Height="auto" Width="auto"  Background="WhiteSmoke" Margin="10,10,10,10" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"></ColumnDefinition>
                    <ColumnDefinition Width="200"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" ></RowDefinition>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="180"></RowDefinition>
                    <RowDefinition Height="50"></RowDefinition>
                </Grid.RowDefinitions>
                <TextBox Name="txtuserid" VerticalAlignment="Top" Visibility="Collapsed"/>
               
                <Label  Name="lblUserName" Content="User Name"   Foreground="#1493D6" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                <Label  Name="txtuserName" VerticalAlignment="Top" Content=""  Grid.Row="0" Grid.Column="1"/>
               
                <Label Name="lblroles" Content="Select roles" Foreground="#1493D6" FontWeight="Bold"  Grid.Row="1" Grid.Column="0"  VerticalAlignment="Bottom"/>
                <ListBox Name="listroles" Height="180" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding TheList}">
                </ListBox>
                <StackPanel Margin="0 5 10 0" Name="stkAdd" Grid.Row="3"  Grid.Column="0" Grid.ColumnSpan="2"  Visibility="Visible"  HorizontalAlignment="Right" Orientation="Horizontal" >
                    <Button Margin="0 0 5 0"  Name="btnAdd"  Content="Save" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#00C79A" Width="90" Click="btnAdd_Click"/>
                    <Button  Name="btnAddCancel" Content="Cancel" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#F07562" Click="btnAddCancel_Click" Width="90"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
