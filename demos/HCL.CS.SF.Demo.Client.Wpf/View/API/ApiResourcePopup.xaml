<Window x:Class="HCL.CS.SF.DemoClientWpfApp.View.API.ApiResourcePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        Title="ApiResourcePopup" Height="450" Width="600" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid  Height="auto" Width="auto" Background="#5D6D7E" Margin="10,10,10,5">
        <Grid.ColumnDefinitions></Grid.ColumnDefinitions>
        <Grid.RowDefinitions></Grid.RowDefinitions>
        <Grid Height="auto" Width="auto" Background="WhiteSmoke" Margin="20,20,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition ></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Label Name="lblName"   Foreground="#1493D6" FontWeight="Bold" Width="200" Grid.Row="1" Grid.Column="0"/>
            <TextBox Height="35" Name="txtName" Text=""  Margin="0 0 0 10" Grid.Row="1" Grid.Column="1" Width="250"/>

            <Label   Name="lblDisplayName"  Foreground="#1493D6" FontWeight="Bold" Width="200" Grid.Row="2" Grid.Column="0"/>
            <TextBox Height="35" Name="txtDisplayName" Text=""  Margin="0 0 0 10" Grid.Row="2" Grid.Column="1" Width="250"/>

            <Label  Name="lblDescription" Foreground="#1493D6" FontWeight="Bold" Width="200" Grid.Row="3" Grid.Column="0"/>
            <TextBox Height="35" Name="txtDescription" Text=""  Margin="0 0 0 10" Grid.Row="3" Grid.Column="1" Width="250"/>

            <Label Name="lblClaimType" Foreground="#1493D6" FontWeight="Bold" Width="200" Grid.Row="1" Grid.Column="0"/>
            <TextBox Height="35" Name="txtClaimType" Grid.Row="1" Grid.Column="1" Width="250"/>


            <StackPanel Name="stkAdd" Grid.Row="4"  Grid.Column="1"  Visibility="{Binding AddPanelVisibility}"  Orientation="Horizontal">
                <Button Margin="12,10,10,1" Name="btnAdd"  Content="Add" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#00C79A" Width="90" Click="Add_Click"/>
                <Button Margin="2,10,10,1" Name="btnAddCancel" Content="Cancel" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#F07562" Click="AddCancel_Click" Width="90"/>
            </StackPanel>
            <StackPanel Name="stkUpdate" Grid.Row="4" Grid.Column="1"  Orientation="Horizontal">
                <Button Margin="12,10,10,1"  Name="btnUpdate" Content="Update" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#00C79A" Width="90" Click="btnUpdate_Click" />
                <Button Margin="2,10,10,1" Name="btnCancel" Content="Cancel" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#F07562" Width="90" Click="btnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
