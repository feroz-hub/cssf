<Window x:Class="HCL.CS.SF.DemoClientWpfApp.View.API.RoleClaimPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HCL.CS.SF.DemoClientWpfApp.View.API"
        mc:Ignorable="d"
        Title="RoleClaimPopup" Height="350" Width="550" WindowStartupLocation="CenterScreen" HorizontalAlignment="Center">
    <Grid Height="auto" Width="auto" HorizontalAlignment="Center" Background="#5D6D7E">
        <TextBlock Name="txtRoleId" Visibility="Hidden"/>
        <Grid Background="WhiteSmoke" HorizontalAlignment="Center"  Margin="10,10,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
                <ColumnDefinition Width="300"></ColumnDefinition>
                <ColumnDefinition Width="60"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Text="Role Claims:" FontWeight="Bold" Margin="10" Grid.Column="1" Grid.Row="0"/>
            <ListBox Name="lstRoleClaims" Margin="10" Grid.Row="0" Grid.Column="2" ItemsSource="{Binding }"></ListBox>
            <StackPanel Name="stkbtn" Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
                <Button x:Name="btnAdd" Width="20" Height="30"  ToolTip="Add Role claim" Foreground="Black" Click="btnAddpanel_Click"  Background="Transparent" BorderBrush="Transparent">
                    <Image Height="15" Stretch="Fill" Width="15" Source="/Image/AddIcon.png" />
                </Button>
                <Button x:Name="btndelete"  Width="20" Height="30"   ToolTip="Delete Role claim" Click="btndelete_Click" Foreground="Black" Background="Transparent" BorderBrush="Transparent" >
                    <Image Height="15" Width="15" Source="/Image/Deleteicon.png" />
                </Button>
            </StackPanel>
            <StackPanel Name="stkAddClaim" Grid.Row="1" Grid.Column="0" Margin="10 20 10 10" Grid.ColumnSpan="3" Orientation="Horizontal">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ClaimType:" FontWeight="Bold" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Height="30" Margin="0,0,220,0" VerticalAlignment="Bottom"/>
                    <TextBox Height="25" Name="txtClaimType" Text="" Grid.Row="0" Grid.Column="2" Width="200"/>

                    <TextBlock Text="ClaimVlaue:" FontWeight="Bold" Grid.Column="1" Grid.Row="1"/>
                    <TextBox Height="25" Name="txtClaimValue" Text=""  Grid.Column="2" Grid.Row="1" Width="200"/>

                    <StackPanel Name="stkAdd" Grid.Row="2"  Grid.Column="2" Grid.ColumnSpan="3" Grid.RowSpan="2"  Visibility="{Binding AddPanelVisibility}"  Orientation="Horizontal">
                        <Button Margin="10,10" Name="btnAddClaim"  Content="Add" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#00C79A" Width="90" Click="btnAddClaim_Click"/>
                        <Button  Name="btnAddCancel" Content="Cancel" Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#F07562" Click="btnAddCancel_Click" Width="90"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
