<UserControl x:Class="HCL.CS.SF.DemoClientWpfApp.View.ChangePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:ChangePasswordViewModel}"
             mc:Ignorable="d" HorizontalAlignment="Center">
    <StackPanel>
        <Grid x:Name="LayoutRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="2,2,20,5" Background="Transparent">
                <Grid Height="auto" Width="auto"   Margin="10,10,10,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="30" ></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="30"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition Width="auto"></ColumnDefinition>
                        <ColumnDefinition Width="auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label  Grid.Column="1"  Grid.Row="0" FontSize="20" Foreground="#85409d" Margin="0,10,0,0" HorizontalAlignment="Left" Name="ChangeLoginPassWord" >
                        <Bold>Change Password</Bold>
                    </Label>

                    <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="#1493D6" Grid.Row="1"  Name="textBlockOldPassword" Text="Old Password:" VerticalAlignment="Top"/>
                    <TextBox Grid.Column="2" Width="200" Grid.Row="1" Height="25"   Name="LoginOldPassword" Text="{Binding LoginOldPassword, Mode=TwoWay}" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="#1493D6" Grid.Row="2"   Name="textBlockNewPassword" Text="New Password:" VerticalAlignment="Top"/>
                    <PasswordBox Grid.Column="2" Grid.Row="2" Height="25"   Name="LoginNewPassword" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="#1493D6" Grid.Row="3"   Name="textBlockConfirmPassword" Text="Confirm Password:" VerticalAlignment="Top"/>
                    <PasswordBox Grid.Column="2"  Grid.Row="3" Height="25"  Name="LoginConfirmPassword"  VerticalAlignment="Top"/>
                    <Button Content="Update"  Style="{DynamicResource RoundCorner}" Foreground="White" Height="40" Background="#00C79A" Width="90" Command="{Binding Path=LoginPasswordChangeCommand}" CommandParameter="{Binding ElementName=LoginNewPassword}" Grid.Column="2" Grid.Row="4" Grid.RowSpan="2"/>
                </Grid>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
