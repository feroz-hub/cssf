<UserControl x:Class="HCL.CS.SF.DemoClientWpfApp.View.UserManagement.UserLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:MainWindowViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300" >

    <UserControl.DataContext>
        <viewmodel:MainWindowViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid Height="auto" Width="auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Column="1" Grid.Row="0" FontWeight="Bold" HorizontalAlignment="Left" Foreground="#85409d" FontSize="25"  Name="txtHederUserName" Text="Login" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Grid.Row="1"  FontWeight="Bold" HorizontalAlignment="Left" Foreground="#1493D6" FontSize="12"  Name="txtLoginUserName" Text="User Name:" VerticalAlignment="Top"/>
            <TextBox Grid.Column="1" Grid.Row="2" Height="25"   Name="LoginUsername" Text="{Binding LoginUserName, Mode=TwoWay}" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left" FontWeight="Bold" Foreground="#1493D6" FontSize="12"  Name="textBlockLoginPassword" Text="Password:" VerticalAlignment="Top"/>
            <PasswordBox Grid.Column="1" Grid.Row="4" Height="25"   Name="LoginPasswordBox" VerticalAlignment="Top"/>
            <Button Grid.Row="5"  Content="Login" FontWeight="Bold" Style="{DynamicResource RoundCorner}"  Foreground="White" Background="#00C79A" Width="200"  Command="{Binding Path=LoginCommand}" CommandParameter="{Binding ElementName=LoginPasswordBox}" Margin="43,2,43,1" />
            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="6" HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Button Grid.Column="0" Margin="0 0 5 0" Grid.Row="0" Height="20" FontWeight="Bold"  Content="Verify account |" Cursor="Hand" 
                         Command="{Binding GotoEmailVerifyCommand}" >
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <TextBlock TextDecorations="Underline"><InlineUIContainer>  
                                    <ContentPresenter />
                                </InlineUIContainer></TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Foreground" Value="Blue" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter Property="Foreground" Value="Red" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="0" Margin="0 0 5 0"  Height="20" HorizontalAlignment="Left" FontWeight="Bold" Content="Register User | " 
                        Cursor="Hand" Command="{Binding Path=GotoRegisterCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock TextDecorations="Underline">  
                                                <ContentPresenter />
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="Blue" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter Property="Foreground" Value="Red" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="2" Grid.Row="0" Height="20" Margin="0 0 5 0"   HorizontalAlignment="Left" FontWeight="Bold" Content="Forgot Password " Cursor="Hand" Command="{Binding Path=GotoForgotPassworCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock TextDecorations="Underline">  
                                             <ContentPresenter />
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="Blue" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter Property="Foreground" Value="Red" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
