<UserControl x:Class="HCL.CS.SF.DemoClientWpfApp.View.ResetPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCL.CS.SF.DemoClientWpfApp.View.UserManagement" xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel" xmlns:intr="http://schemas.microsoft.com/xaml/behaviors" d:DataContext="{d:DesignInstance Type=viewmodel:ResetPasswordViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="450" HorizontalAlignment="Center" >
    <intr:Interaction.Triggers>
        <intr:EventTrigger EventName="Loaded">
            <intr:InvokeCommandAction Command="{Binding OnLoadCommand}"/>
        </intr:EventTrigger>
    </intr:Interaction.Triggers>
    
    <Grid Margin="20,10,0,0">
        <Grid Height="auto" Width="auto">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
  

            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" FontSize="25" Foreground="#85409d"  HorizontalAlignment="Left" x:Name="ResetLoginPassWord" >
                <Bold>
                    <Run Text="Reset Password"/>
                </Bold>
            </Label>

            <TextBlock Grid.Column="0" FontWeight="Bold" Foreground="#1493D6" FontSize="12" Grid.Row="1"   Name="textResetUserNameToken" Text="User Name:" VerticalAlignment="Top"/>
            <TextBox Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="1" Text ="{Binding ResetTokenUserName}"   Name="ResetUserNameToken" Width="200" VerticalAlignment="Top" Height="25" Margin="0 0 10 10" />
            <Button Content="Generate token" Foreground="White" Style="{DynamicResource RoundCorner}" Background="#d68b41" Width="100" Command="{Binding ResetPasswordTokenCommand}" CommandParameter="{Binding ElementName=LoginNewResetPasswordBox}" Grid.Column="2" Grid.Row="1" Grid.RowSpan="2" Height="30"  VerticalAlignment="Top" />

            <TextBlock Grid.Column="0" Visibility="{Binding ResetPanelVisibility}" FontWeight="Bold" Foreground="#1493D6" FontSize="12" Grid.Row="2"  x:Name="textResetToken" Text="Reset Token:" VerticalAlignment="Top"/>
            <TextBox Grid.Column="1" Visibility="{Binding ResetPanelVisibility}" Grid.Row="2"  Text="{Binding ResetPasswordToken}" x:Name="RestToken" Margin="0 0 0 10" Height="25" VerticalAlignment="Top"/>

            <TextBlock FontWeight="Bold" Visibility="{Binding ResetPanelVisibility}" Foreground="#1493D6" FontSize="12" Grid.Column="0" Grid.Row="3"   x:Name="textBlockResetNewPassword" Text="New Password:" VerticalAlignment="Top"/>
            <PasswordBox Grid.Column="1" Visibility="{Binding ResetPanelVisibility}"  Grid.Row="3"   x:Name="LoginNewResetPasswordBox" Height="25" Margin="0 0 0 10" VerticalAlignment="Top"/>

            <TextBlock FontWeight="Bold" Visibility="{Binding ResetPanelVisibility}" Foreground="#1493D6" FontSize="12" Grid.Column="0" Grid.Row="4"   x:Name="textBlockRestConfirmPassword" Text="Confirm Password:" VerticalAlignment="Top"/>
            <PasswordBox Grid.Column="1" Visibility="{Binding ResetPanelVisibility}" Grid.Row="4"   x:Name="LoginResetConfirmPasswordBox" Height="25" Margin="0 0 0 10" VerticalAlignment="Top"/>

            <StackPanel Height="35" Grid.Row="5" Grid.RowSpan="2"  Grid.Column="1" Visibility="{Binding ResetPanelVisibility}" Grid.ColumnSpan="2" Orientation="Horizontal">
                <Button Margin="10,1"   Content="Update" Style="{DynamicResource RoundCorner}" Foreground="White" Background="#00C79A" Width="90" Command="{Binding ResetPasswordChangeCommand}" CommandParameter="{Binding ElementName=LoginNewResetPasswordBox}"  />
                <Button Margin="10,1"  Content="Cancel" Style="{DynamicResource RoundCorner}" Foreground="White"  Background="#F07562" Width="90" Command="{Binding ResetPasswordCancelCommand}" CommandParameter="{Binding ElementName=LoginNewResetPasswordBox}"  />
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
