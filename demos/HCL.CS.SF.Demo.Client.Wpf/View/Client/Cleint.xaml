<UserControl x:Class="HCL.CS.SF.DemoClientWpfApp.View.Cleint"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCL.CS.SF.DemoClientWpfApp.View" xmlns:intr="http://schemas.microsoft.com/xaml/behaviors" xmlns:viewmodel="clr-namespace:HCL.CS.SF.DemoClientWpfApp.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:ClientViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" HorizontalAlignment="Center">
    <intr:Interaction.Triggers>
        <intr:EventTrigger EventName="Loaded">
            <intr:InvokeCommandAction Command="{Binding OnLoadCommand}"/>
        </intr:EventTrigger>
    </intr:Interaction.Triggers>
    <StackPanel>
        <Grid x:Name="LayoutRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="20,2,20,5" Background="Transparent">
                <Grid  Margin="10,10,10,5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label HorizontalAlignment="Left" HorizontalContentAlignment="Left"  FontSize="15" Foreground="Black" FontWeight="Bold" Content="CLIENT MANAGEMENT"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" >
                        <TextBlock Text="Add Client:" Margin="12,0"  Grid.Row="1" Grid.Column="0" FontWeight="Bold"/>
                        <Button x:Name="btnAdd" Grid.Row="1" Grid.Column="1"   ToolTip="Expand" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Command="{Binding AddClientCommand}" >
                            <Image Height="15" Stretch="Fill" Width="15" Source="/Image/AddIcon.png" />
                        </Button>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="Refresh:"   FontWeight="Bold"/>
                        <Button x:Name="btnRefresh"  ToolTip="Expand" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Command="{Binding RefreshCommand}" >
                            <Image Height="15" Stretch="Fill" Width="15" Source="/Image/refreshIcon.png" />
                        </Button>
                    </StackPanel>
                    <DataGrid Height="450"  Grid.ColumnSpan="2" AutoGenerateColumns="False" MaxHeight="525"  ItemsSource="{Binding Clients}"   HeadersVisibility="Column"  HorizontalAlignment="Left"    Name="grdKitsGroupingParent" VerticalAlignment="Center"  CanUserAddRows="True"  Grid.Row="2" RowDetailsVisibilityMode="Visible" SelectedItem="{Binding Path=SelectedItem , Mode=TwoWay}" >
                        <DataGrid.Columns>
                            <DataGridTextColumn CanUserReorder="True"   CanUserResize="True" CanUserSort="True" IsReadOnly="False" Width="250" Binding="{Binding Path= Key}" Header="CLIENT ID"  Foreground="Black">
                            </DataGridTextColumn>

                            <DataGridTextColumn CanUserReorder="True" CanUserResize="True" CanUserSort="True" IsReadOnly="False" Width="250" Binding="{Binding Value}" Header="CLIENT NAME"  Foreground="Black">
                            </DataGridTextColumn>

                            <DataGridTemplateColumn  Header="UPDATE"   IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="btnUpdate"  ToolTip="Expand" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Tag="{Binding ClientName}" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.UpdateClientCommand}" CommandParameter="{Binding ElementName=grdKitsGroupingParent,Path=SelectedItem}"  >
                                            <Image Height="15" Stretch="Fill" Width="15" Source="/Image/Edit.png" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn  Header="DELETE" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="btndelete" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.DeleteClientCommand}" CommandParameter="{Binding ElementName=grdKitsGroupingParent,Path=SelectedItem}"  ToolTip="Expand" Foreground="Black" Background="Transparent" BorderBrush="Transparent" Tag="{Binding ClientName}" >
                                            <Image Height="15" Width="15" Source="/Image/Deleteicon.png" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
