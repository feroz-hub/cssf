                            <Button  FontWeight="Bold" Background="Transparent" FontSize="12" Foreground="Black" HorizontalAlignment="Center" Content="AUTHORIZATION CODE FLOW" Cursor="Hand" Command="{Binding Path=GotoAuthorizationCommand}">
