                            <TextBox Grid.Column="2" TextWrapping="Wrap" FontWeight="Bold" Grid.ColumnSpan="9"   Grid.Row="4" Height="50"  Margin="0,10,0,0" Name="ROPtxtIdentityToken" Text="{Binding IdentityToken, Mode=TwoWay}" VerticalAlignment="Top"/>

                            <TextBlock Foreground="Black" FontWeight="Bold" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="5" Margin="0,10,0,0" Name="ROPRefreshToken" Text="Refresh Token:" VerticalAlignment="Top"/>
                            <TextBox Grid.Column="2"  Grid.ColumnSpan="8" FontWeight="Bold"   Grid.Row="5" Height="30"  Margin="0,10,0,10" Name="ROPtxtRefreshToken" Text="{Binding RefreshToken, Mode=TwoWay}" VerticalAlignment="Top"/>

                            <TextBlock Foreground="Black" FontWeight="Bold" Grid.Column="1" Grid.Row="6" Margin="0,10,0,0" Name="ROPValidFrom" Text="ValidFrom:" VerticalAlignment="Top"/>
                            <Label Grid.Column="2" Grid.ColumnSpan="3" FontWeight="Bold"   Grid.Row="6"  Margin="0,10,0,10" Name="ROPtxtValidFrom" Content="{Binding ValidFrom, Mode=TwoWay}" VerticalAlignment="Top"/>

                            <TextBlock Foreground="Black" FontWeight="Bold" Grid.Column="1" Grid.Row="7" Margin="0,10,0,0" Name="ROPValidTo" Text="ValidTo:" VerticalAlignment="Top"/>
                            <Label Grid.Column="2" Grid.ColumnSpan="3" FontWeight="Bold"   Grid.Row="7" Margin="0,10,0,10" Name="ROPtxtValidTo" Content="{Binding ValidTo, Mode=TwoWay}" VerticalAlignment="Top"/>
                            <DataGrid   AlternationCount="2" Grid.Column="1"  Name="ROPGrid" Grid.Row="8"  SelectedItem="{Binding Path=SelectedItem , Mode=TwoWay}" IsReadOnly="True" IsSynchronizedWithCurrentItem="True" ItemsSource="{Binding RopClaimGrid}" Grid.ColumnSpan="12" FontSize="11" FontWeight="Regular" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible" AutoGenerateColumns="True" Height="200" Width="900">
                                <DataGrid.InputBindings>
                                    <MouseBinding
                                         MouseAction="LeftDoubleClick"
                                         Command="{Binding DoubleClickCommand}"
                                         CommandParameter="{Binding CollectionView/}"/>
                                </DataGrid.InputBindings>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
                <!--</Border>-->
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
