                            <TextBlock Foreground="Black" FontWeight="Bold" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="5" Margin="0,10,0,0" Name="RefreshToken" Text="Refresh Token:" VerticalAlignment="Top"/>
                            <TextBox Grid.Column="2"  Grid.ColumnSpan="8" FontWeight="Bold"   Grid.Row="5" Height="30"  Margin="0,10,0,10" Name="txtRefreshToken" Text="{Binding RefreshToken, Mode=TwoWay}" VerticalAlignment="Top"/>

