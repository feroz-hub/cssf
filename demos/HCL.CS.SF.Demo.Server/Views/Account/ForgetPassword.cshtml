@model HCL.CS.SF.DemoServerApp.Models.ForgetPasswordViewModel
<h2>@ViewData["Title"]</h2>
<div class="row">
    <div class="col-md-4">
        <form asp-action="ForgetPassword" asp-controller="Account" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <h4>Select mode to send password reset token</h4>
            <hr/>
            <input type="hidden" asp-for="ReturnUrl"/>
            <div class="form-group">
                <label asp-for="UserName">Username:</label>
                <input asp-for="UserName" class="form-control"/>
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <button type="submit" name="button" value="email" class="btn btn-primary">Email</button>
                <button type="submit" name="button" value="sms" class="btn btn-primary">SMS</button>
            </div>
        </form>
    </div>
</div>
@if (ViewBag.Message != null)
{
    <script type="text/javascript">
        window.onload = function () {
            alert("@ViewBag.Message");
        };
    </script>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
