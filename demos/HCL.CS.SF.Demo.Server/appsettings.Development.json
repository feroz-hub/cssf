{
  "Authentication": {
    "Google": {
      "Enabled": false,
      "ClientId": "${HCL.CS.SF_GOOGLE_CLIENT_ID}",
      "ClientSecret": "${HCL.CS.SF_GOOGLE_CLIENT_SECRET}",
      "Authority": "https://accounts.google.com",
      "MetadataAddress": "https://accounts.google.com/.well-known/openid-configuration",
      "CallbackPath": "/auth/external/google/signin-callback",
      "AllowedRedirectHosts": [
        "localhost",
        "admin.localhost"
      ]
    },
    "ExternalAccount": {
      "AutoProvisionEnabled": false,
      "AllowedDomains": [],
      "AllowedDomainsByTenant": {}
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "HCL.CS.SF": {
    "Observability": {
      "EnableMetrics": false
    }
  }
}
