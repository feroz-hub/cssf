# Public URL where this Next.js app is reachable
NEXTAUTH_URL=https://admin.localhost:3001

# Random secret for NextAuth JWT/session encryption
NEXTAUTH_SECRET=X7w7bXF3g4vIK8nTwCKaNkMga0TDyqEREkzmcavNHBs=

# HCL.CS.SF identity issuer base URL
HCL.CS.SF_ISSUER=https://localhost:5001

# OAuth client credentials configured in HCL.CS.SF for this admin app
HCL.CS.SF_CLIENT_ID=REDbgSB6J3jb3N9uolHJH74HzZDKM0wrcxZYf+Xve+I=
HCL.CS.SF_CLIENT_SECRET=8pS9klVkqg3ntTN+dEp9biqEdc9OlHAajB3mM9EiLPM=

# HCL.CS.SF API base URL used for /Security/Api/* calls
HCL.CS.SF_API_BASE_URL=https://localhost:5001

# Demo Server base URL (health check + Google sign-in). Must be the URL where HCL.CS.SF.Demo.Server runs.
# If you run only the Identity API on 5001, run the Demo Server separately (e.g. on 5002) and set this:
# HCL.CS.SF_DEMO_SERVER_BASE_URL=https://localhost:5002
HCL.CS.SF_DEMO_SERVER_BASE_URL=https://localhost:5001

# Space-separated scopes requested at login.
HCL.CS.SF_SCOPES=openid profile email offline_access phone HCL.CS.SF.apiresource.manage HCL.CS.SF.client.manage HCL.CS.SF.user.read HCL.CS.SF.user.write HCL.CS.SF.role.manage HCL.CS.SF.identityresource.manage HCL.CS.SF.adminuser.manage HCL.CS.SF.securitytoken.manage HCL.CS.SF.notification.read HCL.CS.SF.notification.manage

# Optional explicit endpoints (fallback to OIDC discovery if omitted)
HCL.CS.SF_METADATA_ADDRESS=https://localhost:5001/.well-known/openid-configuration
HCL.CS.SF_TOKEN_ENDPOINT=https://localhost:5001/security/token
HCL.CS.SF_REVOCATION_ENDPOINT=https://localhost:5001/security/revocation

# Where HCL.CS.SF should return user after end-session
HCL.CS.SF_POST_LOGOUT_REDIRECT_URI=https://admin.localhost:3001/login

# Set true only when HCL.CS.SF /security/endsession is fully configured and stable.
# Keep false to use local app logout only.
HCL.CS.SF_ENABLE_FEDERATED_LOGOUT=false

# Development-only self-signed cert bypass for our custom fetch wrapper. Keep false in production.
HCL.CS.SF_ALLOW_INSECURE_TLS=true

# Allow NextAuth's internal OAuth fetch to work with self-signed certs (dev only).
# Required because NextAuth fetches OIDC discovery and exchanges auth codes using its own fetch,
# which doesn't use our custom HCLCSSFFetch wrapper. NEVER set this in production.
NODE_TLS_REJECT_UNAUTHORIZED=0
